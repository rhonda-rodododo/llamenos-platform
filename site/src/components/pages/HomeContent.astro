---
import Hero from '../Hero.astro';
import FeatureCard from '../FeatureCard.astro';
import ScreenshotGallery from '../ScreenshotGallery.astro';
import { type Lang, defaultLang } from '../../i18n/config';
import { getTranslation } from '../../i18n/utils';
import { home } from '../../i18n/translations/home';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(home, lang);

// Fall back to English sections if the locale hasn't been translated yet
const enSections = home['en'].features.sections;
const sections = t.features.sections.length > 0 ? t.features.sections : enSections;

function lp(path: string) {
  return lang === defaultLang ? path : `/${lang}${path}`;
}

// Section accent colors for variety
const sectionAccents: Record<string, string> = {
  security: 'from-accent/20 to-accent/5',
  telephony: 'from-blue-500/20 to-blue-500/5',
  messaging: 'from-violet-500/20 to-violet-500/5',
  platforms: 'from-emerald-500/20 to-emerald-500/5',
  'case-management': 'from-amber-500/20 to-amber-500/5',
  deployment: 'from-rose-500/20 to-rose-500/5',
};
const sectionBorders: Record<string, string> = {
  security: 'border-accent/30',
  telephony: 'border-blue-500/30',
  messaging: 'border-violet-500/30',
  platforms: 'border-emerald-500/30',
  'case-management': 'border-amber-500/30',
  deployment: 'border-rose-500/30',
};
const sectionPills: Record<string, string> = {
  security: 'bg-accent/10 text-accent-bright border-accent/20',
  telephony: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  messaging: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
  platforms: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'case-management': 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  deployment: 'bg-rose-500/10 text-rose-400 border-rose-500/20',
};
---

<Hero
  badge={t.hero.badge}
  title={t.hero.title}
  titleAccent={t.hero.titleAccent}
  description={t.hero.description}
  cta={t.hero.cta}
  ctaSecondary={t.hero.ctaSecondary}
  ctaHref={lp('/download')}
  ctaSecondaryHref={lp('/docs/deploy')}
/>

<!-- Feature sections -->
<section class="py-20 border-t border-border">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl mb-16">
      <h2 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl">{t.features.heading}</h2>
      <p class="mt-3 text-fg-muted">{t.features.subtitle}</p>
    </div>

    <div class="space-y-20">
      {sections.map((section) => {
        const accentGradient = sectionAccents[section.id] ?? sectionAccents.security;
        const borderColor = sectionBorders[section.id] ?? sectionBorders.security;
        const pillColor = sectionPills[section.id] ?? sectionPills.security;
        const colsClass = section.items.length === 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2 lg:grid-cols-4';
        return (
          <div>
            <!-- Section header -->
            <div class={`rounded-xl border ${borderColor} bg-gradient-to-r ${accentGradient} p-5 mb-6`}>
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-1">
                <span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium ${pillColor} w-fit`}>
                  {section.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}
                </span>
              </div>
              <h3 class="text-lg font-bold text-fg mt-2">{section.heading}</h3>
              <p class="text-sm text-fg-muted mt-1">{section.oneliner}</p>
            </div>

            <!-- Feature cards grid -->
            <div class={`grid grid-cols-1 gap-4 ${colsClass}`}>
              {section.items.map((f) => (
                <FeatureCard title={f.title} description={f.description} icon={f.icon} />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Screenshot gallery -->
<section class="py-20 border-t border-border">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl mb-3">{t.screenshots.heading}</h2>
      <p class="text-fg-muted max-w-2xl mx-auto">{t.screenshots.subtitle}</p>
    </div>
    <ScreenshotGallery />
  </div>
</section>

<!-- Security callout -->
<section class="py-20 border-t border-border">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-2xl border border-border bg-bg-card p-8 md:p-12">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-medium text-accent-bright mb-4">
          Reviewed by a Signal cryptographer
        </div>
        <h2 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl mb-4">{t.security.heading}</h2>
        <p class="text-fg-muted leading-relaxed mb-6">{t.security.description}</p>
        <a
          href={lp('/security')}
          class="inline-flex items-center gap-2 text-accent-bright font-medium text-sm hover:text-accent transition-colors"
        >
          {t.security.link}
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Stats bar -->
<section class="py-12 border-t border-border bg-bg-soft/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-3xl font-bold text-accent-bright">8</div>
        <div class="text-sm text-fg-muted mt-1">telephony providers</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-accent-bright">5</div>
        <div class="text-sm text-fg-muted mt-1">messaging channels</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-accent-bright">57</div>
        <div class="text-sm text-fg-muted mt-1">crypto domain labels</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-accent-bright">13</div>
        <div class="text-sm text-fg-muted mt-1">languages built in</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 border-t border-border">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl mb-4">{t.deploy.heading}</h2>
    <p class="text-fg-muted max-w-xl mx-auto mb-8">{t.deploy.description}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={lp('/download')}
        class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-bright"
      >
        {t.deploy.cta}
      </a>
      <a
        href="https://github.com/rhonda-rodododo/llamenos-hotline"
        class="inline-flex items-center justify-center rounded-lg border border-border bg-bg-soft px-6 py-3 text-sm font-medium text-fg transition-colors hover:bg-bg-card"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t.deploy.github}
      </a>
    </div>
  </div>
</section>
