---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { type Lang, defaultLang, languages } from '../i18n/config';
import { getTranslation } from '../i18n/utils';
import { common } from '../i18n/translations/common';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description = 'Llámenos documentation', lang = defaultLang } = Astro.props;
const dir = languages[lang].dir;
const t = getTranslation(common, lang);

function lp(path: string) {
  return lang === defaultLang ? path : `/${lang}${path}`;
}

const sections = [
  {
    heading: t.docs.setupDeployment,
    items: [
      { href: lp('/docs'), label: t.docs.overview },
      { href: lp('/docs/getting-started'), label: t.docs.gettingStarted },
      { href: lp('/docs/self-hosting'), label: t.docs.selfHosting },
      { href: lp('/docs/deploy-docker'), label: t.docs.deployDocker },
      { href: lp('/docs/deploy-kubernetes'), label: t.docs.deployKubernetes },
    ],
  },
  {
    heading: t.docs.userGuides,
    items: [
      { href: lp('/docs/admin-guide'), label: t.docs.adminGuide },
      { href: lp('/docs/volunteer-guide'), label: t.docs.volunteerGuide },
      { href: lp('/docs/reporter-guide'), label: t.docs.reporterGuide },
    ],
  },
  {
    heading: t.docs.voiceProviders,
    items: [
      { href: lp('/docs/telephony-providers'), label: t.docs.telephonyProviders },
      { href: lp('/docs/setup-twilio'), label: t.docs.setupTwilio },
      { href: lp('/docs/setup-signalwire'), label: t.docs.setupSignalwire },
      { href: lp('/docs/setup-vonage'), label: t.docs.setupVonage },
      { href: lp('/docs/setup-plivo'), label: t.docs.setupPlivo },
      { href: lp('/docs/setup-asterisk'), label: t.docs.setupAsterisk },
      { href: lp('/docs/webrtc-calling'), label: t.docs.webrtcCalling },
    ],
  },
  {
    heading: t.docs.messagingChannels,
    items: [
      { href: lp('/docs/setup-sms'), label: t.docs.setupSms },
      { href: lp('/docs/setup-whatsapp'), label: t.docs.setupWhatsapp },
      { href: lp('/docs/setup-signal'), label: t.docs.setupSignal },
    ],
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/docs';
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{title} | Llámenos Docs</title>
</head>
<body class="min-h-screen flex flex-col">
  <Header lang={lang} />
  <div class="flex-1 pt-20">
    <div class="mx-auto max-w-6xl px-6 py-10 lg:flex lg:gap-10">
      <!-- Sidebar -->
      <aside class="mb-8 lg:mb-0 lg:w-56 lg:shrink-0">
        <nav class="lg:sticky lg:top-24 space-y-6">
          {sections.map(section => (
            <div>
              <h2 class="text-xs font-semibold uppercase tracking-wider text-fg-dim mb-3">{section.heading}</h2>
              <ul class="space-y-1">
                {section.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'block px-3 py-2 rounded-lg text-sm transition-colors',
                        currentPath === item.href.replace(/\/$/, '')
                          ? 'text-accent-bright bg-accent/10 font-medium border-l-2 border-accent'
                          : 'text-fg-muted hover:text-fg hover:bg-bg-soft/50'
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Content -->
      <article class="prose min-w-0 flex-1">
        <slot />
      </article>
    </div>
  </div>
  <Footer lang={lang} />
</body>
</html>
