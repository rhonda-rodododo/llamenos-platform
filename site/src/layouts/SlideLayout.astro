---
import type { ParsedSlide } from '../utils/slides';
// Note: global.css intentionally NOT imported — slides are self-contained
// to avoid Tailwind resets and marketing site styles interfering with
// the 1920x1080 presentation canvas scaling.

interface Props {
  title: string;
  author?: string;
  event?: string;
  date?: Date;
  description?: string;
  slides: ParsedSlide[];
  slug: string;
}

const { title, author, event, date, description, slides, slug } = Astro.props;
const slideCount = slides.length;
const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description ?? `${title} — presentation slides`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | Llámenos Slides</title>

  <style is:global>
    /* ─── Reset & Base ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --slide-bg: oklch(0.1 0.01 250);
      --slide-bg-soft: oklch(0.14 0.01 250);
      --slide-bg-card: oklch(0.18 0.015 250);
      --slide-fg: oklch(0.96 0 0);
      --slide-fg-muted: oklch(0.72 0 0);
      --slide-accent: oklch(0.60 0.14 195);
      --slide-accent-bright: oklch(0.72 0.15 195);
      --slide-amber: oklch(0.78 0.14 70);
      --slide-green: oklch(0.7 0.17 155);
      --slide-red: oklch(0.65 0.2 25);
      --slide-border: oklch(0.22 0.01 250);
      --font-sans: "DM Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
      --font-mono: "JetBrains Mono", ui-monospace, "Cascadia Code", "Fira Mono", monospace;
      --slide-w: 1920px;
      --slide-h: 1080px;
      --scale: 1;
    }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: var(--slide-bg);
      color: var(--slide-fg);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Viewport & Deck ──────────────────────────────────────── */
    #slides-viewport {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: oklch(0.07 0.008 250);
    }

    #slides-scaler {
      position: relative;
      width: var(--slide-w);
      height: var(--slide-h);
      transform-origin: top left;
      transform: scale(var(--scale));
    }

    /* ─── Individual Slides ─────────────────────────────────────── */
    .slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 120px;
      background: var(--slide-bg);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      overflow: hidden;
    }

    .slide.active {
      opacity: 1;
      pointer-events: auto;
    }

    /* Background image slides */
    .slide[data-bg] {
      background-size: cover;
      background-position: center;
    }
    .slide[data-bg]::before {
      content: '';
      position: absolute;
      inset: 0;
      background: oklch(0.08 0.01 250 / 0.7);
    }
    .slide[data-bg] .slide-inner {
      position: relative;
      z-index: 1;
    }

    .slide-inner {
      max-width: 1600px;
      width: 100%;
      margin: 0 auto;
    }

    /* ─── Title Slide ───────────────────────────────────────────── */
    .slide-layout-title {
      text-align: center;
      align-items: center;
      background: linear-gradient(
        160deg,
        oklch(0.12 0.015 250) 0%,
        oklch(0.1 0.01 250) 60%,
        oklch(0.12 0.02 195) 100%
      );
    }
    .slide-layout-title .slide-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    /* ─── Typography (px units — fixed 1920×1080 canvas) ─────── */
    .slide-inner h1 {
      font-size: 72px;
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--slide-fg);
      margin-bottom: 22px;
    }
    .slide-inner h2 {
      font-size: 52px;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.025em;
      color: var(--slide-fg);
      margin-bottom: 26px;
      padding-bottom: 16px;
      border-bottom: 3px solid var(--slide-accent);
    }
    .slide-inner h3 {
      font-size: 36px;
      font-weight: 600;
      color: var(--slide-accent-bright);
      margin-bottom: 14px;
    }
    .slide-inner p {
      font-size: 30px;
      line-height: 1.6;
      color: var(--slide-fg-muted);
      margin-bottom: 18px;
    }
    .slide-inner ul, .slide-inner ol {
      font-size: 28px;
      line-height: 1.55;
      color: var(--slide-fg-muted);
      padding-left: 48px;
      margin-bottom: 22px;
    }
    .slide-inner li {
      margin-bottom: 12px;
    }
    .slide-inner li::marker {
      color: var(--slide-accent);
    }
    .slide-inner strong {
      color: var(--slide-fg);
      font-weight: 600;
    }
    .slide-inner em {
      color: var(--slide-accent-bright);
      font-style: normal;
      font-weight: 500;
    }

    /* ─── Images / diagrams ──────────────────────────────────── */
    .slide-inner img {
      max-width: 100%;
      max-height: 580px;
      object-fit: contain;
      margin: 0 auto;
      display: block;
    }

    /* Title slide: subtitle after h1 */
    .slide-layout-title .slide-inner h2 {
      font-size: 38px;
      font-weight: 400;
      color: var(--slide-fg-muted);
      border: none;
      padding: 0;
      margin: 0;
    }
    .slide-layout-title .slide-inner p {
      font-size: 26px;
      color: oklch(0.55 0.08 195);
      margin-top: 24px;
    }

    /* ─── Code blocks ──────────────────────────────────────────── */
    .slide-inner pre {
      background: var(--slide-bg-card);
      border: 1px solid var(--slide-border);
      border-radius: 8px;
      padding: 20px 24px;
      overflow-x: auto;
      font-size: 22px;
      line-height: 1.6;
      margin: 12px 0;
    }
    .slide-inner code {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background: var(--slide-bg-card);
      border: 1px solid var(--slide-border);
      border-radius: 4px;
      padding: 2px 8px;
      color: var(--slide-amber);
    }
    .slide-inner pre code {
      background: none;
      border: none;
      padding: 0;
      color: var(--slide-fg-muted);
      font-size: 1em;
    }

    /* ─── Blockquote / Quote slides ─────────────────────────────── */
    .slide-inner blockquote {
      border-left: 4px solid var(--slide-accent);
      padding: 18px 36px;
      margin: 12px 0;
      background: var(--slide-bg-soft);
      border-radius: 0 8px 8px 0;
    }
    .slide-inner blockquote p {
      font-size: 28px;
      font-style: italic;
      color: var(--slide-fg);
    }
    .slide-layout-quote {
      align-items: center;
      background: var(--slide-bg-soft);
    }
    .slide-layout-quote .slide-inner blockquote {
      border-left: 6px solid var(--slide-accent-bright);
      padding: 36px 48px;
    }

    /* ─── Tables ────────────────────────────────────────────────── */
    .slide-inner table {
      width: 100%;
      border-collapse: collapse;
      font-size: 24px;
      margin: 16px 0;
    }
    .slide-inner th {
      text-align: left;
      font-weight: 600;
      color: var(--slide-fg);
      padding: 12px 16px;
      border-bottom: 2px solid var(--slide-accent);
    }
    .slide-inner td {
      padding: 10px 16px;
      color: var(--slide-fg-muted);
      border-bottom: 1px solid var(--slide-border);
    }
    .slide-inner tr:last-child td {
      border-bottom: none;
    }

    /* ─── Two-column layout ─────────────────────────────────────── */
    .slide-columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      width: 100%;
    }
    .slide-col h2 {
      font-size: 38px !important;
      border-bottom: 2px solid var(--slide-accent) !important;
      padding-bottom: 10px !important;
      margin-bottom: 18px !important;
    }
    .slide-col h3 {
      font-size: 28px !important;
      color: var(--slide-accent-bright) !important;
    }
    .slide-col p, .slide-col li {
      font-size: 24px !important;
    }

    /* ─── Fragments (incremental reveal) ─────────────────────────── */
    .fragment[data-fragment-hidden="true"] {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .fragment.visible {
      opacity: 1;
      transform: none;
    }

    /* ─── UI Overlay ────────────────────────────────────────────── */
    #slide-ui {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 100;
    }

    /* Progress bar */
    #progress-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      background: var(--slide-accent);
      transition: width 0.3s ease;
      pointer-events: none;
    }

    /* Slide counter */
    #slide-counter {
      position: absolute;
      bottom: 1rem;
      right: 1.5rem;
      font-size: 0.875rem;
      color: oklch(0.45 0 0);
      font-family: var(--font-mono);
      pointer-events: none;
      letter-spacing: 0.05em;
    }

    /* Nav hint */
    #nav-hint {
      position: absolute;
      bottom: 1rem;
      left: 1.5rem;
      font-size: 0.8rem;
      color: oklch(0.35 0 0);
      pointer-events: none;
    }

    /* Notes panel */
    #notes-panel {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 30%;
      background: oklch(0.08 0.01 250 / 0.96);
      border-top: 1px solid var(--slide-border);
      padding: 1rem 2rem;
      font-size: 0.9rem;
      color: var(--slide-fg-muted);
      line-height: 1.5;
      display: none;
      overflow-y: auto;
      z-index: 200;
      backdrop-filter: blur(8px);
    }
    #notes-panel.visible { display: block; }
    #notes-panel .notes-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--slide-accent);
      margin-bottom: 0.5rem;
    }

    /* ─── Overview / Grid Mode ──────────────────────────────────── */
    #slides-viewport.overview {
      overflow-y: auto;
      align-items: flex-start;
      justify-content: center;
      padding: 2rem;
    }

    #slides-viewport.overview #slides-scaler {
      position: static;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
      width: 100%;
      height: auto;
      transform: none;
    }

    #slides-viewport.overview .slide {
      position: relative;
      width: 320px;
      height: 180px;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      cursor: pointer;
      border: 2px solid var(--slide-border);
      border-radius: 0.5rem;
      overflow: hidden;
      flex-shrink: 0;
      padding: 16px 24px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    #slides-viewport.overview .slide:hover {
      border-color: var(--slide-accent);
      box-shadow: 0 0 0 2px var(--slide-accent);
    }
    #slides-viewport.overview .slide.active {
      border-color: var(--slide-accent-bright);
      box-shadow: 0 0 0 2px var(--slide-accent-bright);
    }
    #slides-viewport.overview .slide-inner {
      transform: scale(0.18);
      transform-origin: top left;
      width: calc(100% / 0.18);
      pointer-events: none;
    }
    #slides-viewport.overview .slide[data-bg]::before {
      display: none;
    }
    #slides-viewport.overview #slide-ui {
      display: none;
    }

    /* Overview slide numbers */
    .slide-overview-num {
      display: none;
      position: absolute;
      top: 4px;
      right: 8px;
      font-size: 0.6rem;
      color: var(--slide-fg-muted);
      font-family: var(--font-mono);
      z-index: 10;
    }
    #slides-viewport.overview .slide-overview-num { display: block; }

    /* ─── Fullscreen button ─────────────────────────────────────── */
    #fullscreen-btn {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 300;
      background: oklch(0.18 0.01 250 / 0.8);
      border: 1px solid var(--slide-border);
      border-radius: 0.375rem;
      color: var(--slide-fg-muted);
      padding: 0.4rem 0.6rem;
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: auto;
      backdrop-filter: blur(4px);
    }
    #fullscreen-btn:hover { opacity: 1; color: var(--slide-fg); }
    #slides-viewport:hover #fullscreen-btn { opacity: 0.5; }

    /* Back to decks link */
    #back-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 300;
      background: oklch(0.18 0.01 250 / 0.8);
      border: 1px solid var(--slide-border);
      border-radius: 0.375rem;
      color: var(--slide-fg-muted);
      padding: 0.4rem 0.8rem;
      cursor: pointer;
      font-size: 0.8rem;
      text-decoration: none;
      opacity: 0;
      transition: opacity 0.2s;
      backdrop-filter: blur(4px);
    }
    #back-link:hover { opacity: 1; color: var(--slide-fg); }
    #slides-viewport:hover #back-link { opacity: 0.5; }

    /* ─── Print Styles ──────────────────────────────────────────── */
    @media print {
      html, body { overflow: visible; height: auto; background: white; }
      #slides-viewport {
        position: static;
        display: block;
        overflow: visible;
        background: white;
      }
      #slides-scaler {
        position: static;
        display: block;
        width: 100%;
        height: auto;
        transform: none;
      }
      .slide {
        position: relative;
        display: flex !important;
        opacity: 1 !important;
        pointer-events: auto !important;
        page-break-after: always;
        page-break-inside: avoid;
        width: 100%;
        height: 56.25vw; /* 16:9 */
        border: 1px solid #ddd;
      }
      .slide-inner { max-width: 100%; }
      .slide-inner h1 { font-size: 2.5rem; }
      .slide-inner h2 { font-size: 1.8rem; }
      .slide-inner p, .slide-inner li { font-size: 1rem; color: #333; }
      .slide-inner h1, .slide-inner h2, .slide-inner h3 { color: #111; }
      .fragment[data-fragment-hidden="true"] { opacity: 1 !important; transform: none !important; }
      #slide-ui, #notes-panel, #fullscreen-btn, #back-link { display: none !important; }
    }
  </style>
</head>
<body>

<a href="/slides/" id="back-link">← All Decks</a>

<div id="slides-viewport">
  <div id="slides-scaler">
    {slides.map((slide, i) => (
      <section
        class={`slide ${slide.classes.join(' ')} ${i === 0 ? 'active' : ''}`}
        data-index={i}
        data-bg={slide.background ?? undefined}
        style={slide.background ? `background-image: url(${slide.background})` : undefined}
        data-notes={slide.notes || undefined}
        data-fragment-count={String((slide.html.match(/class="fragment"/g) ?? []).length)}
      >
        <span class="slide-overview-num">{i + 1}</span>
        <div class="slide-inner" set:html={slide.html} />
      </section>
    ))}
  </div>

  <div id="slide-ui">
    <div id="progress-bar" style="width: 0%"></div>
    <div id="slide-counter">1 / {slideCount}</div>
    <div id="nav-hint">← → navigate · Esc overview · F fullscreen · N notes</div>
  </div>
</div>

<button id="fullscreen-btn" aria-label="Toggle fullscreen" title="Toggle fullscreen (F)">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
  </svg>
  FS
</button>

<div id="notes-panel">
  <div class="notes-label">Speaker Notes</div>
  <div id="notes-content"></div>
</div>

<script define:vars={{ slideCount, slug }}>
  // ── State ──────────────────────────────────────────────────────────
  let current = 0;
  let fragmentIndex = -1;
  let isOverview = false;
  let notesVisible = false;
  const totalSlides = slideCount;

  const viewport = document.getElementById('slides-viewport');
  const scaler = document.getElementById('slides-scaler');
  const progressBar = document.getElementById('progress-bar');
  const counter = document.getElementById('slide-counter');
  const notesPanel = document.getElementById('notes-panel');
  const notesContent = document.getElementById('notes-content');

  // ── Scaling ────────────────────────────────────────────────────────
  function scale() {
    if (isOverview) return;
    const W = 1920, H = 1080;
    const vw = window.innerWidth, vh = window.innerHeight;
    const s = Math.min(vw / W, vh / H);
    scaler.style.setProperty('transform', `scale(${s})`);
    // Center the scaled content
    const scaledW = W * s, scaledH = H * s;
    scaler.style.setProperty('margin-left', `${(vw - scaledW) / 2}px`);
    scaler.style.setProperty('margin-top', `${(vh - scaledH) / 2}px`);
  }
  window.addEventListener('resize', scale);
  scale();

  // ── Slide helpers ──────────────────────────────────────────────────
  function slides() {
    return Array.from(document.querySelectorAll('.slide'));
  }
  function currentSlide() {
    return slides()[current];
  }
  function fragments(slide) {
    return Array.from(slide.querySelectorAll('.fragment'));
  }

  // ── Navigation ─────────────────────────────────────────────────────
  function goTo(index, resetFragments = true) {
    const all = slides();
    if (index < 0 || index >= totalSlides) return;

    all[current].classList.remove('active');
    current = index;
    all[current].classList.add('active');

    if (resetFragments) {
      fragmentIndex = -1;
      fragments(all[current]).forEach(f => {
        f.setAttribute('data-fragment-hidden', 'true');
        f.classList.remove('visible');
      });
    }

    updateUI();

    if (isOverview) {
      all[current].scrollIntoView({ block: 'nearest' });
    }
  }

  function next() {
    if (isOverview) return;
    const frags = fragments(currentSlide());
    const nextFrag = frags.findIndex((f, i) => i > fragmentIndex && f.getAttribute('data-fragment-hidden') === 'true');
    if (nextFrag !== -1) {
      frags[nextFrag].removeAttribute('data-fragment-hidden');
      frags[nextFrag].classList.add('visible');
      fragmentIndex = nextFrag;
    } else if (current < totalSlides - 1) {
      goTo(current + 1);
    }
  }

  function prev() {
    if (isOverview) return;
    const frags = fragments(currentSlide());
    if (fragmentIndex >= 0) {
      frags[fragmentIndex].setAttribute('data-fragment-hidden', 'true');
      frags[fragmentIndex].classList.remove('visible');
      fragmentIndex--;
    } else if (current > 0) {
      goTo(current - 1);
    }
  }

  function updateUI() {
    const pct = totalSlides > 1 ? (current / (totalSlides - 1)) * 100 : 100;
    progressBar.style.width = `${pct}%`;
    counter.textContent = `${current + 1} / ${totalSlides}`;

    const noteText = currentSlide().getAttribute('data-notes') || '';
    notesContent.textContent = noteText;
    if (notesVisible && !noteText) {
      // keep panel open but show empty state
    }
  }

  // ── Overview ────────────────────────────────────────────────────────
  function toggleOverview() {
    isOverview = !isOverview;
    viewport.classList.toggle('overview', isOverview);

    if (isOverview) {
      // In overview mode, re-apply scaling per mini-slide
      scaler.style.removeProperty('transform');
      scaler.style.removeProperty('margin-left');
      scaler.style.removeProperty('margin-top');
      // Attach click handlers
      slides().forEach((s, i) => {
        s.onclick = () => {
          toggleOverview();
          goTo(i);
        };
      });
    } else {
      slides().forEach(s => { s.onclick = null; });
      scale();
    }
    updateUI();
  }

  // ── Notes ────────────────────────────────────────────────────────
  function toggleNotes() {
    notesVisible = !notesVisible;
    notesPanel.classList.toggle('visible', notesVisible);
    const noteText = currentSlide().getAttribute('data-notes') || '';
    notesContent.textContent = noteText;
  }

  // ── Fullscreen ──────────────────────────────────────────────────
  document.getElementById('fullscreen-btn').addEventListener('click', toggleFullscreen);
  function toggleFullscreen() {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {});
    } else {
      document.exitFullscreen().catch(() => {});
    }
  }

  // ── Keyboard ────────────────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
      case ' ':
        e.preventDefault();
        if (isOverview) { goTo(Math.min(current + 1, totalSlides - 1)); }
        else { next(); }
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
        e.preventDefault();
        if (isOverview) { goTo(Math.max(current - 1, 0)); }
        else { prev(); }
        break;
      case 'Escape':
        e.preventDefault();
        toggleOverview();
        break;
      case 'f':
      case 'F':
        if (!isOverview) { e.preventDefault(); toggleFullscreen(); }
        break;
      case 'n':
      case 'N':
        e.preventDefault();
        toggleNotes();
        break;
      case 'Home':
        e.preventDefault();
        goTo(0);
        break;
      case 'End':
        e.preventDefault();
        goTo(totalSlides - 1);
        break;
    }
  });

  // ── Touch / Swipe ────────────────────────────────────────────────
  let touchStartX = 0, touchStartY = 0;
  document.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      if (dx < 0) next(); else prev();
    }
  }, { passive: true });

  // ── Hash-based deep linking ──────────────────────────────────────
  function readHash() {
    const n = parseInt(location.hash.replace('#', ''), 10);
    if (!isNaN(n) && n >= 1 && n <= totalSlides) goTo(n - 1);
  }
  window.addEventListener('hashchange', readHash);
  if (location.hash) readHash();

  function updateHash() {
    history.replaceState(null, '', `#${current + 1}`);
  }

  // Patch goTo to update hash
  const _goTo = goTo;
  goTo = function(index, reset) {
    _goTo(index, reset);
    updateHash();
  };

  // ── Init ─────────────────────────────────────────────────────────
  updateUI();
</script>

</body>
</html>
