# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# First admin's public key (hex format, generated by: bun run scripts/bootstrap-admin.ts)
ADMIN_PUBKEY=hex_public_key_here

# Admin decryption public key (separate from identity key — for note/hub encryption)
# ADMIN_DECRYPTION_PUBKEY=hex_decryption_pubkey_here

# Server Nostr secret (for signing relay events). Generate with: openssl rand -hex 32
# SERVER_NOSTR_SECRET=hex_secret_here
