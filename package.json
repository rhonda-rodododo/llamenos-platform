{
  "name": "llamenos",
  "version": "0.19.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run deploy:demo && bun run deploy:site",
    "deploy:demo": "bun run build && bunx wrangler deploy",
    "deploy:next": "bun run build && bunx wrangler deploy --env next",
    "deploy:site": "cd site && bun run deploy",
    "dev:worker": "bunx wrangler dev",
    "dev:tunnel": "bash scripts/dev-tunnel.sh",
    "build:node": "node esbuild.node.mjs",
    "build:docker": "bun run build && bun run build:node",
    "start:node": "PLATFORM=node node dist/server/index.js",
    "typecheck": "bunx tsc --noEmit",
    "bootstrap-admin": "bun run scripts/bootstrap-admin.ts",
    "test": "bunx playwright test",
    "test:live": "bunx playwright test --config playwright.live.config.ts",
    "test:ui": "bunx playwright test --ui",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:preview": "git-cliff --unreleased",
    "version:bump": "bun run scripts/bump-version.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@tanstack/react-router": "^1.158.4",
    "@tanstack/router-plugin": "^1.158.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.11.9",
    "i18next": "^25.8.4",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.0",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-phone-number-input": "^3.4.14",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.3",
    "esbuild": "^0.27.3",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.12.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.63.0"
  }
}
