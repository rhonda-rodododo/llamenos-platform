{
  "name": "llamenos",
  "version": "0.19.2",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/worker",
    "site"
  ],
  "scripts": {
    "dev": "bunx tauri dev --project-path apps/desktop",
    "dev:vite": "vite",
    "build": "vite build",
    "deploy": "bun run deploy:api && bun run deploy:site",
    "deploy:api": "bunx wrangler deploy --config apps/worker/wrangler.jsonc",
    "deploy:site": "cd site && bun run deploy",
    "dev:worker": "bunx wrangler dev --config apps/worker/wrangler.jsonc",
    "dev:tunnel": "bash scripts/dev-tunnel.sh",
    "build:node": "node esbuild.node.mjs",
    "build:docker": "bun run build:node",
    "start:node": "PLATFORM=node node dist/server/index.js",
    "typecheck": "bunx tsc --noEmit",
    "bootstrap-admin": "bun run scripts/bootstrap-admin.ts",
    "test": "PLAYWRIGHT_TEST=true bunx playwright test",
    "test:build": "PLAYWRIGHT_TEST=true bun run build",
    "test:live": "bunx playwright test --config playwright.live.config.ts",
    "test:ui": "PLAYWRIGHT_TEST=true bunx playwright test --ui",
    "test:desktop": "bunx wdio tests/desktop/wdio.conf.ts",
    "test:docker:up": "cd deploy/docker && docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --build --wait app",
    "test:docker:down": "cd deploy/docker && docker compose -f docker-compose.yml -f docker-compose.test.yml down -v",
    "test:worker": "bunx vitest run --config vitest.unit.config.ts",
    "test:worker:unit": "bunx vitest run --config vitest.unit.config.ts",
    "test:worker:integration": "bunx vitest run --config vitest.integration.config.ts",
    "test:worker:watch": "bunx vitest --config vitest.unit.config.ts",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:preview": "git-cliff --unreleased",
    "version:bump": "bun run scripts/bump-version.ts",
    "tauri:dev": "bunx tauri dev --project-path apps/desktop",
    "tauri:build": "bunx tauri build --project-path apps/desktop",
    "tauri:icon": "bunx tauri icon --project-path apps/desktop",
    "crypto:test": "cargo test --manifest-path packages/crypto/Cargo.toml",
    "crypto:clippy": "cargo clippy --manifest-path packages/crypto/Cargo.toml -- -D warnings",
    "crypto:fmt": "cargo fmt --manifest-path packages/crypto/Cargo.toml --check",
    "i18n:codegen": "bun run packages/i18n/tools/i18n-codegen.ts",
    "i18n:validate": "bun run packages/i18n/tools/i18n-codegen.ts --validate",
    "codegen": "bun run packages/protocol/tools/codegen.ts",
    "codegen:check": "bun run packages/protocol/tools/codegen.ts --check",
    "test-specs:validate": "bun packages/test-specs/tools/validate-coverage.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@fivesheepco/cloudflare-apns2": "^13.0.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@tanstack/react-router": "^1.158.4",
    "@tanstack/router-plugin": "^1.158.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fcm-cloudflare-workers": "^2.0.1",
    "hono": "^4.11.9",
    "i18next": "^25.8.4",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.0",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-phone-number-input": "^3.4.14",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.18",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.3",
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "esbuild": "^0.27.3",
    "playwright-bdd": "^8.4.2",
    "quicktype-core": "^23.2.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.12.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "webdriverio": "^9.24.0",
    "wrangler": "^4.63.0"
  }
}
