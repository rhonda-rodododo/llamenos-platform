{
  "name": "llamenos",
  "version": "0.19.4",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/worker",
    "site"
  ],
  "scripts": {
    "dev": "bunx tauri dev apps/desktop",
    "dev:vite": "vite",
    "build": "vite build",
    "deploy": "bun run deploy:site",
    "deploy:site": "cd site && bun run deploy",
    "dev:tunnel": "bash scripts/dev-tunnel.sh",
    "build:server": "bun build src/server/index.ts --target=bun --outdir=dist/server",
    "build:docker": "bun run build:server",
    "start:server": "PLATFORM=bun bun --sql-preconnect src/server/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "check:ipc-allowlist": "bash scripts/check-ipc-allowlist.sh",
    "bootstrap-admin": "bun run scripts/bootstrap-admin.ts",
    "test": "PLAYWRIGHT_TEST=true bunx playwright test",
    "test:build": "PLAYWRIGHT_TEST=true bun run build",
    "test:live": "bunx playwright test --config playwright.live.config.ts",
    "test:ui": "PLAYWRIGHT_TEST=true bunx playwright test --ui",
    "test:backend:bdd": "scripts/test-backend-bdd.sh",
    "test:all": "scripts/test-orchestrator.sh",
    "test:desktop": "scripts/test-desktop.sh",
    "test:desktop:wdio": "bunx wdio tests/desktop/wdio.conf.ts",
    "test:docker:up": "cd deploy/docker && docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --build --wait app",
    "test:docker:down": "cd deploy/docker && docker compose -f docker-compose.yml -f docker-compose.test.yml down -v",
    "test:worker": "scripts/test-worker.sh",
    "test:worker:unit": "bunx vitest run --config vitest.unit.config.ts",
    "test:worker:integration": "bunx vitest run --config vitest.integration.config.ts",
    "test:worker:watch": "bunx vitest --config vitest.unit.config.ts",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:preview": "git-cliff --unreleased",
    "version:bump": "bun run scripts/bump-version.ts",
    "tauri:dev": "bunx tauri dev apps/desktop",
    "tauri:build": "bunx tauri build apps/desktop",
    "tauri:icon": "bunx tauri icon apps/desktop",
    "crypto:test": "cargo test --manifest-path packages/crypto/Cargo.toml",
    "crypto:clippy": "cargo clippy --manifest-path packages/crypto/Cargo.toml -- -D warnings",
    "crypto:fmt": "cargo fmt --manifest-path packages/crypto/Cargo.toml --check",
    "crypto:wasm": "packages/crypto/scripts/build-wasm.sh",
    "crypto:wasm:dev": "packages/crypto/scripts/build-wasm.sh dev",
    "i18n:codegen": "bun run packages/i18n/tools/i18n-codegen.ts",
    "i18n:validate": "bun run packages/i18n/tools/i18n-codegen.ts --validate",
    "i18n:validate:android": "bun run packages/i18n/tools/validate-strings.ts android",
    "i18n:validate:ios": "bun run packages/i18n/tools/validate-strings.ts ios",
    "i18n:validate:desktop": "bun run packages/i18n/tools/validate-strings.ts desktop",
    "i18n:validate:all": "bun run packages/i18n/tools/validate-strings.ts all",
    "codegen": "bun run packages/protocol/tools/codegen.ts",
    "codegen:check": "bun run packages/protocol/tools/codegen.ts --check",
    "test-specs:validate": "bun packages/test-specs/tools/validate-coverage.ts",
    "mac:run": "bash scripts/mac-run.sh",
    "ios:status": "bash scripts/ios-build.sh status",
    "ios:setup": "bash scripts/ios-build.sh setup",
    "ios:build": "bash scripts/ios-build.sh build",
    "ios:test": "bash scripts/ios-build.sh test",
    "ios:xcframework": "bash scripts/ios-build.sh xcframework",
    "ios:uitest": "bash scripts/ios-build.sh uitest",
    "ios:all": "bash scripts/ios-build.sh all",
    "crypto:test:mobile": "cargo test --manifest-path packages/crypto/Cargo.toml --features mobile",
    "test:android": "scripts/test-android.sh",
    "test:android:direct": "cd apps/android && ./gradlew testDebugUnitTest lintDebug assembleDebugAndroidTest",
    "test:android:e2e": "cd apps/android && ./gradlew connectedDebugAndroidTest",
    "test:ios": "scripts/test-ios.sh",
    "test:crypto": "scripts/test-crypto.sh",
    "test:feature": "scripts/test-feature.sh",
    "test:changed": "scripts/test-changed.sh",
    "test:android:e2e:parallel": "bash scripts/android-parallel-e2e.sh",
    "android:emulators:start": "bash scripts/android-parallel-e2e.sh --emulators-only",
    "android:emulators:stop": "bash scripts/android-parallel-e2e.sh --stop",
    "android:sdk:setup": "bash scripts/setup-android-sdk.sh",
    "dev:server": "bash scripts/dev-bun.sh",
    "dev:server:stop": "bash scripts/dev-bun.sh stop",
    "dev:server:logs": "bash scripts/dev-bun.sh logs",
    "dev:node": "bash scripts/dev-bun.sh",
    "migrate:status": "bun run scripts/migrate.ts status",
    "migrate:up": "bun run scripts/migrate.ts up",
    "migrate:rollback": "bun run scripts/migrate.ts rollback",
    "tauri:manifest": "bun run scripts/generate-update-manifest.ts",
    "load:calls": "tests/load/run.sh calls",
    "load:messages": "tests/load/run.sh messages",
    "load:mixed": "tests/load/run.sh mixed",
    "load:burst": "tests/load/run.sh burst",
    "load:all": "tests/load/run.sh all",
    "lint": "eslint src/ apps/worker/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@fivesheepco/cloudflare-apns2": "^13.0.0",
    "@hono/standard-validator": "^0.2.2",
    "@huggingface/transformers": "^4.2.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scalar/hono-api-reference": "^0.10.10",
    "@scure/base": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/router-plugin": "^1.167.28",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "fcm-cloudflare-workers": "^2.0.1",
    "hono": "^4.12.15",
    "hono-openapi": "^1.3.0",
    "i18next": "^26.0.8",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "openai": "^4.77.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-phone-number-input": "^3.4.16",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "playwright-bdd": "^8.5.0",
    "postgres": "^3.4.9",
    "quicktype-core": "^23.2.6",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.5",
    "webdriverio": "^9.27.0",
    "wrangler": "^4.85.0"
  },
  "overrides": {
    "protobufjs": ">=7.5.5"
  }
}