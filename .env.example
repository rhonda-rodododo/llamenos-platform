# Llamenos Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
#
# Required variables are marked with (REQUIRED).
# Variables with defaults can be left at their default values for development.

# ── Core ──────────────────────────────────────────────────────

# (REQUIRED) PostgreSQL password for the llamenos database user
PG_PASSWORD=change-me-secure-password

# (REQUIRED) Nostr pubkey of the initial admin account
# Generate with: bun run bootstrap-admin
ADMIN_PUBKEY=

# (REQUIRED) 64-char hex secret for HMAC authentication tokens
# Generate with: openssl rand -hex 32
HMAC_SECRET=

# (REQUIRED) Nostr secret key for the server identity
# Generate with: openssl rand -hex 32
SERVER_NOSTR_SECRET=

# Display name for this hotline instance
HOTLINE_NAME=Llamenos Hotline

# Deployment environment (production | staging | development)
ENVIRONMENT=production

# ── Object Storage (S3-compatible / RustFS) ───────────────────

# (REQUIRED) S3 access key (username)
S3_ACCESS_KEY=llamenos-s3

# (REQUIRED) S3 secret key (password) — use a strong random value
# Generate with: openssl rand -hex 32
S3_SECRET_KEY=

# S3 bucket name for file uploads
S3_BUCKET=llamenos-files

# ── TLS / Domain ───────────────────────────────────────────────

# Public domain name (used by Caddy for TLS and CoTURN realm)
DOMAIN=example.com

# ACME email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# HTTP/HTTPS port overrides (defaults: 80/443)
# HTTP_PORT=80
# HTTPS_PORT=443

# ── Telephony: Twilio ──────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Telephony: Asterisk PBX (profile: asterisk) ───────────────

# (REQUIRED when asterisk profile active) ARI password
# Must match password in deploy/docker/asterisk-config/ari.conf
# Generate with: openssl rand -hex 16
ARI_PASSWORD=

# ARI username (default matches ari.conf)
ARI_USERNAME=llamenos

# (REQUIRED when asterisk profile active) Webhook shared secret between
# Asterisk bridge and the app
# Generate with: openssl rand -hex 32
BRIDGE_SECRET=

# SIP provider credentials (written to Asterisk at bridge startup via ARI)
# Leave blank to skip SIP trunk registration (local testing only)
SIP_BRIDGE_URL=
PBX_TYPE=asterisk

# SIP port overrides (defaults: 5060/5060/5061)
# SIP_UDP_PORT=5060
# SIP_TCP_PORT=5060
# SIPS_PORT=5061

# ── Telephony: Kamailio SIP Proxy (profile: telephony) ────────

# SIP domain for Kamailio (usually matches DOMAIN)
KAMAILIO_SIP_DOMAIN=${DOMAIN:-localhost}

# ── Telephony: CoTURN STUN/TURN relay (profile: telephony) ───

# (REQUIRED when telephony profile active) TURN server shared secret
# Generate with: openssl rand -hex 32
TURN_SECRET=

# TURN port overrides (defaults: 3478)
# TURN_UDP_PORT=3478
# TURN_TCP_PORT=3478

# ── Signal Messaging (profile: signal) ────────────────────────

# (REQUIRED when signal profile active) API key for the signal-notifier sidecar
# Generate with: openssl rand -hex 32
NOTIFIER_API_KEY=

# Signal phone number registered with signal-cli
SIGNAL_REGISTERED_NUMBER=

# Optional API key for signal-cli REST API (leave blank if not configured)
SIGNAL_BRIDGE_API_KEY=

# ── Monitoring: GlitchTip (profile: monitoring) ───────────────

# (REQUIRED when monitoring profile active)
# Generate with: openssl rand -hex 32
GLITCHTIP_SECRET_KEY=

GLITCHTIP_DOMAIN=https://errors.example.com
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_FROM_EMAIL=noreply@example.com

# GlitchTip DSN for client-side crash reporting (set in app after GlitchTip setup)
GLITCHTIP_DSN=

# ── AI / Inference: Ollama (profile: inference) ──────────────

# Ollama model to pull and use for AI features
OLLAMA_MODEL=llama3.2

# ── Transcription: Whisper (profile: transcription) ───────────

# Whisper model (default: base — fast, reasonable accuracy)
WHISPER_MODEL=Systran/faster-whisper-base

# Compute device (cpu | cuda | auto)
WHISPER_DEVICE=cpu

# Override Whisper URL if running externally
# WHISPER_URL=http://whisper:8080/v1/audio/transcriptions
