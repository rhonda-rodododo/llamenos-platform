# Live telephony E2E test configuration
# Copy to .env.live and fill in real values

# Twilio credentials (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone numbers
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Hotline number (receives incoming calls)
TWILIO_TEST_CALLER=+1XXXXXXXXXX    # Test caller number (simulates a caller)

# Staging secret for test-reset endpoint
E2E_TEST_SECRET=generate-a-random-secret-here

# Staging deployment URL
LIVE_BASE_URL=https://demo-next.llamenos-hotline.com

# Staging admin nsec (from bootstrap flow — needed for test login)
STAGING_ADMIN_NSEC=nsec1...
