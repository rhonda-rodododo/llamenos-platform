"help_title" = "Help";
"help_vol_calls_detail" = "When a caller dials the hotline, all on-shift volunteers ring simultaneously. The first volunteer to pick up handles the call — all other rings are cancelled. Calls are routed based on your shift schedule and availability.";
"help_vol_calls_title" = "How calls work";
"help_vol_encryption_detail" = "Your secret key (nsec) never leaves your device. Notes and messages are encrypted locally before being sent to the server. Even if the server is compromised, your data remains private.";
"help_vol_encryption_title" = "Encryption basics";
"help_vol_notes_detail" = "Create notes during or after calls to document interactions. Notes support custom fields defined by your admin. All note content is end-to-end encrypted — only you and admins can read them.";
"help_vol_notes_title" = "Taking notes";
"help_vol_safety_detail" = "Lock the app when stepping away. Use PIN protection to prevent unauthorized access. If you're in a dangerous situation, use Emergency Wipe in Settings to permanently delete all app data from this device.";
"help_vol_safety_title" = "Staying safe";
"help_vol_shift_detail" = "Clock in when your shift starts to begin receiving calls. Use break mode when you need a pause — you'll stop receiving calls but stay logged in. Clock out at the end of your shift.";
