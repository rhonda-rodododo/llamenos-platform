"help_faq_shifts_a" = "Use the Shift Schedule tab in the Admin Panel to create recurring shifts and assign volunteers.";
"help_faq_shifts_q" = "How do I manage shifts?";
"help_faq_spam_a" = "Add numbers to the Ban List in the Admin Panel. You can also enable voice CAPTCHA and rate limiting.";
"help_faq_spam_q" = "How do I block spam callers?";
