"help_admin_audit_detail" = "Every action is logged in a tamper-evident chain. View who answered calls, created notes, and made changes. The hash chain ensures logs cannot be modified after the fact.";
"help_admin_audit_title" = "Audit logs";
"help_admin_guide" = "Admin Guide";
"help_admin_guide_header" = "Admin Guide";
"help_admin_intro" = "As an admin, you manage volunteers, shifts, call settings, and security features.";
"help_admin_reports_detail" = "Review incident reports filed by volunteers. View contact timelines showing all interactions with a caller. Caller identifiers are HMAC-hashed for privacy.";
"help_admin_reports_title" = "Reports & contacts";
"help_admin_shifts_detail" = "Set up recurring shift schedules with ring groups. Configure fallback groups for when no scheduled shift is active. Volunteers can only receive calls when clocked into their shift.";
"help_admin_shifts_title" = "Shift scheduling";
"help_admin_spam_detail" = "Enable voice CAPTCHA to filter automated calls. Configure rate limiting per caller. Manage ban lists to block known bad actors. All settings can be adjusted in real-time.";
"help_admin_spam_title" = "Spam mitigation";
"help_admin_tip1" = "Invite volunteers or reporters from the Volunteers page — choose their role when creating the invite";
"help_admin_tip2" = "Set up shifts with time ranges and assigned volunteers for automatic call routing";
"help_admin_tip3" = "Configure telephony, transcription, CAPTCHA, and rate limiting in Admin Settings";
"help_admin_tip4" = "Monitor volunteer status and active calls from your dashboard";
"help_admin_tip5" = "Review the Audit Log for a history of all system events";
"help_admin_volunteers_detail" = "Invite new volunteers with invite codes. Assign roles, manage permissions, and deactivate accounts as needed. Volunteer personal information is only visible to admins.";
"help_admin_volunteers_title" = "Managing volunteers";
"help_faq_admin" = "Administration";
"help_faq_admin_a1" = "Go to Admin Panel > Invites and create a new invite code. Share the code securely with the volunteer. They'll use it during onboarding to register with your hub.";
"help_faq_admin_a2" = "Go to Admin Panel > Ban List and add the caller's phone number. Banned callers will hear a message and be disconnected automatically.";
"help_faq_admin_a3" = "Yes. The Audit Log in the Admin Panel shows all actions: calls answered, notes created, shifts started/ended, and more. The log is tamper-evident with hash chaining.";
"help_faq_admin_header" = "FAQ: Admin";
"help_faq_admin_q1" = "How do I add a new volunteer?";
"help_faq_admin_q2" = "How do I ban a caller?";
"help_faq_admin_q3" = "Can I see all volunteer activity?";
"help_faq_break_a" = "When on break, incoming calls are not routed to you. Other on-shift volunteers will still receive them. Use the break toggle on your dashboard or press Ctrl+Shift+B.";
"help_faq_break_q" = "What does \\\"On Break\\\" do?";
"help_faq_calls" = "Calls & Shifts";
"help_faq_calls_a1" = "Make sure you are clocked in for your shift and not on break. Check that your internet connection is stable (the relay connection indicator should be green).";
"help_faq_calls_a2" = "If you don't answer, the call continues ringing for other on-shift volunteers. The first volunteer to pick up handles the call. Missed calls are logged in the dashboard.";
"help_faq_calls_header" = "FAQ: Calls";
"help_faq_calls_q1" = "Why am I not receiving calls?";
"help_faq_calls_q2" = "What happens if I miss a call?";
"help_faq_device_a" = "Go to Settings > Device Link and scan the QR code from your other device.";
"help_faq_device_q" = "How do I link another device?";
"help_faq_encrypt_a" = "Yes. Notes are encrypted end-to-end using your keypair before leaving your device. Only you and authorized admins can decrypt them. The server never sees plaintext.";
"help_faq_encrypt_q" = "How is my data encrypted?";
"help_faq_export_a" = "Yes. Go to Notes and use the Export button. Notes are exported encrypted — you'll need your secret key to decrypt them.";
"help_faq_export_q" = "Can I export my notes?";
"help_faq_getting_started" = "Getting Started";
"help_faq_getting_started_header" = "FAQ: Getting Started";
"help_faq_gs_a1" = "Ask your admin for an invite code. Enter the hub URL, create or import your identity, and set a PIN. You'll be ready to receive calls once you clock in for your shift.";
"help_faq_gs_a2" = "Your nsec is your secret key — like a password that proves your identity. It's generated on your device and never sent to the server. Back it up securely; if you lose it, you'll need a new identity.";
"help_faq_gs_a3" = "Yes. Use the Device Link feature in Settings to securely transfer your identity to another device using a QR code and encrypted key exchange.";
"help_faq_gs_q1" = "How do I get started?";
"help_faq_gs_q2" = "What is an nsec?";
"help_faq_gs_q3" = "Can I use multiple devices?";
"help_faq_invite_a" = "Go to Volunteers and click \\\"Invite Volunteer\\\". Choose the role (Volunteer, Admin, or Reporter), fill in their name and phone, and share the invite link. Each invite code is single-use and expires in 7 days.";
"help_faq_invite_q" = "How do I add volunteers?";
"help_faq_key_a" = "Your key is stored encrypted on this device, protected by your PIN. During onboarding you received a recovery key — use it to restore access on a new device. You can also link devices via QR code from Settings. Contact your admin if you've lost both your PIN and recovery key.";
"help_faq_key_q" = "What is my secret key and where do I find it?";
"help_faq_login_a" = "Enter your 6-digit PIN on the login page to unlock your key store. If you have a passkey set up, you can use that instead. To set up a new device, use the \\\"Link this device\\\" option to scan a QR code from your primary device.";
"help_faq_login_q" = "How do I log in?";
"help_faq_notes" = "Notes & Encryption";
"help_faq_notes_a1" = "Yes. Notes are end-to-end encrypted with a unique key per note. Only you and your admins can decrypt them. The server never sees the plaintext content.";
"help_faq_notes_a2" = "Notes are append-only for security. You can add additional notes but cannot modify existing ones. This ensures a reliable audit trail.";
"help_faq_notes_header" = "FAQ: Notes";
"help_faq_notes_q1" = "Are my notes private?";
"help_faq_notes_q2" = "Can I edit a note after saving?";
"help_faq_provider_a" = "Go to Admin Settings > Telephony Provider. Select your provider, enter credentials, and test the connection before saving. Supported providers: Twilio, SignalWire, Vonage, Plivo, Asterisk.";
"help_faq_provider_q" = "How do I change the telephony provider?";
"help_faq_pwa_a" = "Yes. In your browser, look for 'Install' or 'Add to Home Screen' in the menu. The app will install as 'Hotline' for security — it doesn't reveal the organization name.";
"help_faq_pwa_q" = "Can I install this as an app?";
"help_faq_ring_a" = "Check that: (1) you're on-shift (see your shift schedule), (2) you're not on break, (3) you're not already on a call, and (4) your browser/phone notifications are enabled.";
"help_faq_ring_q" = "Why am I not receiving calls?";
"help_faq_shifts_a" = "Create shifts in the Shifts page with a name, time range, and days of the week. Assign volunteers to each shift. When a shift is active, assigned volunteers receive incoming calls via parallel ringing.";
"help_faq_shifts_q" = "Where do I see my shifts?";
"help_faq_spam_a" = "Three options: (1) Ban specific numbers in the Ban List, (2) Enable Voice CAPTCHA in Admin Settings to require callers to enter digits, (3) Enable Rate Limiting to block repeated calls from the same number.";
"help_faq_spam_q" = "How do I deal with spam calls?";
"help_faq_title" = "Frequently Asked Questions";
"help_faq_voicemail_a" = "If no volunteer answers within the queue timeout, the caller is sent to voicemail (if enabled). Admins can configure the timeout and voicemail settings.";
"help_faq_voicemail_q" = "What happens if no one answers?";
