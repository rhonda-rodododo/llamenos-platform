# ── Apple Account ────────────────────────────────────────────────────────────
# Your Apple ID (email) for the Apple Developer account.
APPLE_ID=your@email.com

# ── App Store Connect API Key ─────────────────────────────────────────────────
# Generate at: https://appstoreconnect.apple.com/access/integrations/api
# Role required: App Manager (or Admin)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Paste the full contents of the .p8 key file (including BEGIN/END lines).
# In CI, store as a multi-line secret and export with: export ASC_KEY="$(cat AuthKey_*.p8)"
ASC_KEY=-----BEGIN PRIVATE KEY-----
# ... (paste p8 key contents here)
-----END PRIVATE KEY-----

# ── Match (code-signing certificates repo) ───────────────────────────────────
# SSH or HTTPS URL to the private Git repo that stores encrypted certs/profiles.
# e.g. git@github.com:your-org/llamenos-certificates.git
MATCH_GIT_URL=git@github.com:your-org/llamenos-certificates.git

# Passphrase used by match to encrypt/decrypt the certificates repo.
# Must be the same on every machine and in CI.
MATCH_PASSWORD=changeme-use-a-strong-passphrase

# ── TestFlight ────────────────────────────────────────────────────────────────
# Optional changelog shown to internal TestFlight testers.
TESTFLIGHT_CHANGELOG=Internal build — see git log for details

# ── Legacy (only if NOT using ASC API key) ───────────────────────────────────
# App-specific password generated at appleid.apple.com (two-factor auth bypass).
# Only needed for tools that still require Apple ID + password auth.
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
