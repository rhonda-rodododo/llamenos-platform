<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ExportOptions for App Store distribution.

  Signing strategy: matches `apps/ios/project.yml` which sets
  CODE_SIGN_STYLE=Automatic. Xcode handles provisioning profiles via
  `xcodebuild -allowProvisioningUpdates`. `teamID` must match the
  DEVELOPMENT_TEAM in project.yml.

  If you ever need to switch to manual signing, set `signingStyle` to
  `manual` and add a `provisioningProfiles` dictionary mapping bundle ID
  to profile name:

      <key>provisioningProfiles</key>
      <dict>
          <key>org.llamenos.hotline</key>
          <string>Llamenos App Store</string>
      </dict>
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store-connect</string>
    <key>destination</key>
    <string>upload</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>uploadSymbols</key>
    <true/>
    <key>compileBitcode</key>
    <false/>
    <key>stripSwiftSymbols</key>
    <true/>
    <key>teamID</key>
    <string>KN6NH935ZU</string>
</dict>
</plist>
