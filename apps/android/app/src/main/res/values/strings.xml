    <string name="help_volunteer_guide">Volunteer Guide</string>
    <string name="help_volunteer_intro">As a volunteer, you answer incoming calls during your assigned shifts and take encrypted notes.</string>
    <string name="help_volunteer_tip1">Your dashboard shows shift status, active calls, and incoming calls</string>
    <string name="help_volunteer_tip2">When a call rings, all on-shift volunteers ring simultaneously — first to answer gets the call</string>
    <string name="help_volunteer_tip3">Take notes during calls — they are encrypted before leaving your device</string>
    <string name="help_volunteer_tip4">Check your shift schedule and sign up for available shifts</string>
    <string name="help_volunteer_tip5">Report spam calls or ban numbers from the admin panel</string>
    <string name="help_admin_guide">Admin Guide</string>
    <string name="help_admin_intro">As an admin, you manage volunteers, shifts, call settings, and security features.</string>
    <string name="help_admin_tip1">Invite volunteers from the Administration panel — choose their role when creating the invite</string>
    <string name="help_admin_tip2">Set up shifts with time ranges and assigned volunteers for automatic call routing</string>
    <string name="help_admin_tip3">Configure ban lists and spam mitigation from the Ban List tab</string>
    <string name="help_admin_tip4">Monitor volunteer status and active calls from your dashboard</string>
    <string name="help_admin_tip5">Review the Audit Log for a history of all system events</string>
    <string name="help_faq_title">Frequently Asked Questions</string>
    <string name="help_faq_getting_started">Getting Started</string>
    <string name="help_faq_login_q">How do I log in?</string>
    <string name="help_faq_login_a">Enter your hub URL and either create a new identity or import an existing nsec key. After setup, you will unlock the app with your PIN.</string>
    <string name="help_faq_key_q">What is my secret key?</string>
    <string name="help_faq_key_a">Your nsec is a Nostr private key that proves your identity. It is encrypted with your PIN and stored securely on your device. If you lose it, your identity cannot be recovered.</string>
    <string name="help_faq_device_q">How do I use multiple devices?</string>
    <string name="help_faq_device_a">Use Device Link in Settings to scan a QR code from the desktop app. This securely transfers your identity to the new device.</string>
    <string name="help_faq_calls">Calls &amp; Shifts</string>
    <string name="help_faq_ring_q">Why am I not receiving calls?</string>
    <string name="help_faq_ring_a">Make sure you are clocked in on the Shifts tab. Check that notifications are enabled in Settings. Only on-shift, non-busy volunteers receive incoming calls.</string>
    <string name="help_faq_break_q">What happens if no one answers?</string>
    <string name="help_faq_break_a">If no volunteer answers within the configured timeout, the call goes to voicemail. Admins can adjust the timeout and fallback behavior.</string>
    <string name="help_faq_notes">Notes &amp; Encryption</string>
    <string name="help_faq_encrypt_q">Are my notes private?</string>
    <string name="help_faq_encrypt_a">Yes. Notes are encrypted on your device before being sent to the server. Only you and your organization\'s admins can read them. The server never sees plaintext.</string>
    <string name="help_faq_export_q">Can I export my notes?</string>
    <string name="help_faq_export_a">Note export is available from the desktop app. Notes remain encrypted and require your key to decrypt.</string>
    <string name="help_faq_admin">Administration</string>
    <string name="help_faq_invite_q">How do I add volunteers?</string>
    <string name="help_faq_invite_a">Go to Administration > Invites and create an invite code. Share the code with the volunteer. Invites expire after 7 days.</string>
    <string name="help_faq_shifts_q">How do shifts work?</string>
    <string name="help_faq_shifts_a">Create shifts in Administration with time ranges and days of the week. Volunteers can sign up for available shifts. Calls are routed to on-shift volunteers via parallel ringing.</string>
    <string name="help_faq_spam_q">How do I deal with spam calls?</string>
    <string name="help_faq_spam_a">Use the Ban List in Administration to block phone numbers. You can add individual bans or bulk import numbers.</string>
