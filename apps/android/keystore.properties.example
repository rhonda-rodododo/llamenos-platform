# Copy this file to keystore.properties (gitignored) and fill in your credentials.
# keystore.properties is read by app/build.gradle.kts for local release builds.
# In CI, set KEYSTORE_PATH / KEYSTORE_PASSWORD / KEY_ALIAS / KEY_PASSWORD env vars instead.
#
# Play App Signing flow:
#   - upload-keystore.jks  = upload key (you control, used to sign APKs/AABs before upload)
#   - Google Play manages the actual app signing key after you opt in to Play App Signing
#
# Note: upload-keystore.jks uses PKCS12 format — storePassword and keyPassword must match.

storeFile=../upload-keystore.jks
storePassword=YOUR_UPLOAD_KEYSTORE_PASSWORD
keyAlias=upload
keyPassword=YOUR_UPLOAD_KEYSTORE_PASSWORD
