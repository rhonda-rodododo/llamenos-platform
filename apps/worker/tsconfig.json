{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@worker/*": ["./*"],
      "@shared/*": ["../../packages/shared/*"],
      "@protocol/*": ["../../packages/protocol/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
