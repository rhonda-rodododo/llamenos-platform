{
  "$schema": "https://raw.githubusercontent.com/nicollasricas/tauri-settings-schema/v2/schema.json",
  "productName": "Hotline",
  "version": "0.19.5",
  "identifier": "org.llamenos.hotline",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../dist/client"
  },
  "app": {
    "security": {
      "pattern": {
        "use": "isolation",
        "options": {
          "dir": "./isolation"
        }
      },
      "csp": {
        "default-src": "'self' customprotocol: asset: isolation:",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "connect-src": "ipc: http://ipc.localhost https://app.llamenos.org wss://relay.llamenos.org",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self'",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "media-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      },
      "freezePrototype": true
    },
    "windows": [
      {
        "title": "Hotline",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "Hotline"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Secure crisis response hotline",
    "longDescription": "Secure, privacy-preserving crisis response hotline with end-to-end encryption",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxRjM1RTU4QkQ4MzE0MkYKUldRdkZJTzlXRjd6NFNTREVwZ0ZXYlVlVUtPd2JxVkplTmZ1SUZoaGhNa1MvMEs4WEdNWEo5TTIK",
      "endpoints": [
        "https://updates.llamenos.org/desktop/latest.json",
        "https://github.com/rhonda-rodododo/llamenos-platform/releases/latest/download/latest.json"
      ]
    }
  }
}