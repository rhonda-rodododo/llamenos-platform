{
  "id": "street-medic",
  "version": "1.1.0",
  "name": "Street Medic",
  "description": "Protest medical encounter tracking with triage, treatment, and follow-up. Designed for volunteer street medic teams providing first aid at protests and actions.",
  "author": "Llamenos Project",
  "license": "CC-BY-SA-4.0",
  "tags": [
    "medical",
    "protest",
    "triage",
    "street-medic"
  ],
  "extends": [],
  "labels": {
    "en": {
      "medical_encounter.label": "Medical Encounter",
      "medical_encounter.labelPlural": "Medical Encounters",
      "medical_encounter.description": "A patient encounter during a protest or action, including triage, treatment, and disposition"
    },
    "es": {
      "medical_encounter.label": "Encuentro Medico",
      "medical_encounter.labelPlural": "Encuentros Medicos",
      "medical_encounter.description": "Un encuentro con un paciente durante una protesta o accion"
    }
  },
  "entityTypes": [
    {
      "name": "medical_encounter",
      "label": "medical_encounter.label",
      "labelPlural": "medical_encounter.labelPlural",
      "description": "medical_encounter.description",
      "icon": "stethoscope",
      "color": "#22c55e",
      "category": "case",
      "numberPrefix": "ME",
      "numberingEnabled": true,
      "defaultAccessLevel": "assigned",
      "piiFields": [
        "allergies",
        "medications",
        "vital_signs"
      ],
      "allowSubRecords": false,
      "allowFileAttachments": true,
      "allowInteractionLinks": true,
      "showInNavigation": true,
      "showInDashboard": true,
      "statuses": [
        {
          "value": "triaged",
          "label": "Triaged",
          "color": "#f59e0b",
          "order": 1
        },
        {
          "value": "treating",
          "label": "Treating",
          "color": "#3b82f6",
          "order": 2
        },
        {
          "value": "treated",
          "label": "Treated",
          "color": "#22c55e",
          "order": 3
        },
        {
          "value": "transported",
          "label": "Transported to Hospital",
          "color": "#ef4444",
          "order": 4
        },
        {
          "value": "follow_up",
          "label": "Follow-Up Needed",
          "color": "#8b5cf6",
          "order": 5
        },
        {
          "value": "closed",
          "label": "Closed",
          "color": "#6b7280",
          "order": 6,
          "isClosed": true
        }
      ],
      "defaultStatus": "triaged",
      "closedStatuses": [
        "closed"
      ],
      "severities": [
        {
          "value": "green",
          "label": "Green (Minor)",
          "color": "#22c55e",
          "icon": "heart",
          "order": 1
        },
        {
          "value": "yellow",
          "label": "Yellow (Delayed)",
          "color": "#f59e0b",
          "icon": "alert-triangle",
          "order": 2
        },
        {
          "value": "red",
          "label": "Red (Immediate)",
          "color": "#ef4444",
          "icon": "zap",
          "order": 3
        },
        {
          "value": "black",
          "label": "Black (Deceased/Expectant)",
          "color": "#000000",
          "icon": "x-circle",
          "order": 4
        }
      ],
      "defaultSeverity": "green",
      "contactRoles": [
        {
          "value": "patient",
          "label": "Patient",
          "order": 1
        },
        {
          "value": "medic",
          "label": "Treating Medic",
          "order": 2
        },
        {
          "value": "witness",
          "label": "Witness",
          "order": 3
        },
        {
          "value": "transporter",
          "label": "Hospital Transporter",
          "order": 4
        }
      ],
      "fields": [
        {
          "name": "encounter_datetime",
          "label": "Encounter Date/Time",
          "type": "date",
          "required": true,
          "section": "assessment",
          "order": 1,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "encounter_location",
          "label": "Encounter Location",
          "type": "text",
          "required": false,
          "section": "assessment",
          "helpText": "Where the patient was found/treated (intersection, landmark).",
          "order": 2,
          "indexable": false,
          "accessLevel": "all"
        },
        {
          "name": "patient_identifier",
          "label": "Patient Identifier",
          "type": "text",
          "required": false,
          "section": "assessment",
          "helpText": "Wristband ID or physical description when name is unknown.",
          "order": 3,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "chief_complaint",
          "label": "Chief Complaint",
          "type": "textarea",
          "required": true,
          "section": "assessment",
          "order": 4,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "mechanism_of_injury",
          "label": "Mechanism of Injury",
          "type": "select",
          "required": false,
          "options": [
            {
              "key": "tear_gas",
              "label": "Tear Gas / CS Gas"
            },
            {
              "key": "pepper_spray",
              "label": "Pepper Spray / OC"
            },
            {
              "key": "rubber_bullet",
              "label": "Rubber Bullet / Impact Munition"
            },
            {
              "key": "baton",
              "label": "Baton / Physical Force"
            },
            {
              "key": "lrad",
              "label": "LRAD / Acoustic Device"
            },
            {
              "key": "taser",
              "label": "Taser / Conducted Energy"
            },
            {
              "key": "fall",
              "label": "Fall / Trampling"
            },
            {
              "key": "heat_exhaustion",
              "label": "Heat Exhaustion / Dehydration"
            },
            {
              "key": "panic_attack",
              "label": "Panic Attack / Anxiety"
            },
            {
              "key": "pre_existing",
              "label": "Pre-Existing Condition"
            },
            {
              "key": "other",
              "label": "Other"
            }
          ],
          "section": "assessment",
          "order": 5,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "vital_signs",
          "label": "Vital Signs",
          "type": "textarea",
          "required": false,
          "section": "assessment",
          "helpText": "Pulse, BP, respiration rate, SpO2 if taken.",
          "order": 6,
          "indexable": false,
          "accessLevel": "admin"
        },
        {
          "name": "treatment_provided",
          "label": "Treatment Provided",
          "type": "textarea",
          "required": true,
          "section": "treatment",
          "order": 7,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "medications",
          "label": "Medications Administered",
          "type": "textarea",
          "required": false,
          "section": "treatment",
          "helpText": "Include dosage and route of administration.",
          "order": 8,
          "indexable": false,
          "accessLevel": "admin"
        },
        {
          "name": "allergies",
          "label": "Known Allergies",
          "type": "text",
          "required": false,
          "section": "patient_info",
          "order": 9,
          "indexable": false,
          "accessLevel": "admin"
        },
        {
          "name": "disposition",
          "label": "Disposition",
          "type": "select",
          "required": true,
          "options": [
            {
              "key": "treated_released",
              "label": "Treated & Released"
            },
            {
              "key": "hospital_transport",
              "label": "Hospital Transport"
            },
            {
              "key": "refused_care",
              "label": "Refused Care"
            },
            {
              "key": "left_ama",
              "label": "Left Against Medical Advice"
            }
          ],
          "section": "outcome",
          "order": 10,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "hospital_name",
          "label": "Hospital / Facility",
          "type": "text",
          "required": false,
          "section": "outcome",
          "order": 11,
          "indexable": false,
          "accessLevel": "assigned",
          "showWhen": {
            "field": "disposition",
            "operator": "equals",
            "value": "hospital_transport"
          }
        },
        {
          "name": "follow_up_needed",
          "label": "Follow-Up Needed",
          "type": "checkbox",
          "required": false,
          "section": "outcome",
          "order": 12,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "follow_up_instructions",
          "label": "Follow-Up Instructions",
          "type": "textarea",
          "required": false,
          "section": "outcome",
          "order": 13,
          "indexable": false,
          "accessLevel": "assigned",
          "showWhen": {
            "field": "follow_up_needed",
            "operator": "equals",
            "value": true
          }
        }
      ]
    }
  ],
  "relationshipTypes": [
    {
      "sourceEntityTypeName": "contact",
      "targetEntityTypeName": "medical_encounter",
      "cardinality": "M:N",
      "label": "Medical Encounters",
      "reverseLabel": "Contacts",
      "sourceLabel": "has encounter",
      "targetLabel": "involves",
      "roles": [
        {
          "value": "patient",
          "label": "Patient",
          "order": 1
        },
        {
          "value": "medic",
          "label": "Treating Medic",
          "order": 2
        },
        {
          "value": "witness",
          "label": "Witness",
          "order": 3
        },
        {
          "value": "transporter",
          "label": "Hospital Transporter",
          "order": 4
        }
      ],
      "defaultRole": "patient",
      "cascadeDelete": false,
      "required": true
    }
  ],
  "suggestedRoles": [
    {
      "name": "Medic Team Lead",
      "slug": "medic-team-lead",
      "description": "Coordinates medical team, reviews all encounters, manages follow-ups",
      "permissions": [
        "cases:*",
        "contacts:*",
        "events:*",
        "evidence:*",
        "notes:*",
        "reports:*",
        "shifts:read",
        "volunteers:read",
        "hubs:read"
      ]
    },
    {
      "name": "Street Medic",
      "slug": "street-medic",
      "description": "Provides care and documents encounters in the field",
      "permissions": [
        "cases:create",
        "cases:read-own",
        "cases:update-own",
        "contacts:create",
        "contacts:view",
        "notes:create",
        "notes:read-own",
        "events:read",
        "shifts:read-own",
        "contacts:search"
      ]
    },
    {
      "name": "Follow-Up Coordinator",
      "slug": "follow-up-coordinator",
      "description": "Contacts patients needing follow-up care, coordinates hospital referrals",
      "permissions": [
        "cases:read-all",
        "cases:update",
        "contacts:view",
        "contacts:view-pii",
        "contacts:edit",
        "notes:create",
        "notes:read-all",
        "contacts:search",
        "cases:unlink"
      ]
    }
  ]
}
