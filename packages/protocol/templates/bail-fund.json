{
  "id": "bail-fund",
  "version": "1.0.0",
  "name": "Bail Fund",
  "description": "Community bail fund case management. Tracks bail disbursements, bond types, court date compliance, bail return, and fund accounting. Designed for community bail funds and bail collectives.",
  "author": "Llamenos Project",
  "license": "CC-BY-SA-4.0",
  "tags": [
    "bail",
    "legal",
    "finance"
  ],
  "extends": [],
  "labels": {
    "en": {
      "bail_fund_case.label": "Bail Fund Case",
      "bail_fund_case.labelPlural": "Bail Fund Cases",
      "bail_fund_case.description": "Track bail disbursement, court compliance, and bail return for a defendant"
    },
    "es": {
      "bail_fund_case.label": "Caso del Fondo de Fianza",
      "bail_fund_case.labelPlural": "Casos del Fondo de Fianza",
      "bail_fund_case.description": "Seguimiento del desembolso de fianza, cumplimiento de tribunal y devolucion de fianza"
    }
  },
  "entityTypes": [
    {
      "name": "bail_fund_case",
      "label": "bail_fund_case.label",
      "labelPlural": "bail_fund_case.labelPlural",
      "description": "bail_fund_case.description",
      "icon": "banknote",
      "color": "#16a34a",
      "category": "case",
      "numberPrefix": "BF",
      "numberingEnabled": true,
      "defaultAccessLevel": "assigned",
      "piiFields": [
        "co_signer",
        "docket_number"
      ],
      "allowSubRecords": false,
      "allowFileAttachments": true,
      "allowInteractionLinks": true,
      "showInNavigation": true,
      "showInDashboard": true,
      "statuses": [
        {
          "value": "pending_review",
          "label": "Pending Review",
          "color": "#f59e0b",
          "order": 1
        },
        {
          "value": "approved",
          "label": "Approved",
          "color": "#3b82f6",
          "order": 2
        },
        {
          "value": "bail_posted",
          "label": "Bail Posted",
          "color": "#8b5cf6",
          "order": 3
        },
        {
          "value": "released",
          "label": "Released",
          "color": "#22c55e",
          "order": 4
        },
        {
          "value": "court_monitoring",
          "label": "Court Monitoring",
          "color": "#0ea5e9",
          "order": 5
        },
        {
          "value": "bail_returned",
          "label": "Bail Returned",
          "color": "#6b7280",
          "order": 6,
          "isClosed": true
        },
        {
          "value": "bail_forfeited",
          "label": "Bail Forfeited",
          "color": "#ef4444",
          "order": 7,
          "isClosed": true
        }
      ],
      "defaultStatus": "pending_review",
      "closedStatuses": [
        "bail_returned",
        "bail_forfeited"
      ],
      "severities": [
        {
          "value": "urgent",
          "label": "Urgent (imminent court date, vulnerable)",
          "color": "#ef4444",
          "icon": "alert-triangle",
          "order": 1
        },
        {
          "value": "standard",
          "label": "Standard",
          "color": "#3b82f6",
          "order": 2
        },
        {
          "value": "low",
          "label": "Low",
          "color": "#6b7280",
          "order": 3
        }
      ],
      "defaultSeverity": "standard",
      "contactRoles": [
        {
          "value": "defendant",
          "label": "Defendant",
          "order": 1
        },
        {
          "value": "co_signer",
          "label": "Co-Signer",
          "order": 2
        },
        {
          "value": "attorney",
          "label": "Attorney",
          "order": 3
        },
        {
          "value": "bail_poster",
          "label": "Bail Poster",
          "order": 4
        },
        {
          "value": "support_contact",
          "label": "Support Contact",
          "order": 5
        }
      ],
      "fields": [
        {
          "name": "bail_amount",
          "label": "Bail Amount",
          "type": "number",
          "required": true,
          "section": "bail",
          "order": 1,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "bond_type",
          "label": "Bond Type",
          "type": "select",
          "required": true,
          "options": [
            {
              "key": "cash",
              "label": "Cash Bail"
            },
            {
              "key": "surety",
              "label": "Surety Bond"
            },
            {
              "key": "property",
              "label": "Property Bond"
            },
            {
              "key": "ror",
              "label": "Released on Recognizance"
            },
            {
              "key": "partially_secured",
              "label": "Partially Secured"
            }
          ],
          "section": "bail",
          "order": 2,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "court",
          "label": "Court",
          "type": "text",
          "required": true,
          "section": "court",
          "helpText": "Name of the court handling the case.",
          "order": 3,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "docket_number",
          "label": "Docket / Case Number",
          "type": "text",
          "required": false,
          "section": "court",
          "helpText": "Court-assigned docket or case number.",
          "order": 4,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "charges",
          "label": "Charges",
          "type": "textarea",
          "required": true,
          "section": "legal",
          "helpText": "All known charges. Update as charges are modified.",
          "order": 5,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "amount_disbursed",
          "label": "Amount Disbursed",
          "type": "number",
          "required": false,
          "section": "finance",
          "helpText": "Amount actually disbursed from the bail fund.",
          "order": 6,
          "indexable": false,
          "accessLevel": "admin"
        },
        {
          "name": "court_date",
          "label": "Next Court Date",
          "type": "date",
          "required": true,
          "section": "court",
          "helpText": "Next scheduled court appearance. Update after each appearance.",
          "order": 7,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "court_appearance_made",
          "label": "Court Appearance Made",
          "type": "checkbox",
          "required": false,
          "section": "court",
          "helpText": "Whether the defendant appeared at their most recent court date.",
          "order": 8,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "bail_returned",
          "label": "Bail Returned",
          "type": "checkbox",
          "required": false,
          "section": "finance",
          "helpText": "Whether bail money has been returned to the fund.",
          "order": 9,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "bail_return_amount",
          "label": "Bail Return Amount",
          "type": "number",
          "required": false,
          "section": "finance",
          "helpText": "Amount returned. May differ from amount disbursed due to fees.",
          "order": 10,
          "indexable": false,
          "accessLevel": "admin",
          "showWhen": {
            "field": "bail_returned",
            "operator": "equals",
            "value": true
          }
        },
        {
          "name": "co_signer",
          "label": "Co-Signer",
          "type": "text",
          "required": false,
          "section": "bail",
          "helpText": "Name of co-signer on the bail bond, if applicable.",
          "order": 11,
          "indexable": false,
          "accessLevel": "admin"
        }
      ]
    }
  ],
  "relationshipTypes": [
    {
      "sourceEntityTypeName": "contact",
      "targetEntityTypeName": "bail_fund_case",
      "cardinality": "M:N",
      "label": "Bail Fund Cases",
      "reverseLabel": "Contacts",
      "sourceLabel": "has case",
      "targetLabel": "involves",
      "roles": [
        {
          "value": "defendant",
          "label": "Defendant",
          "order": 1
        },
        {
          "value": "co_signer",
          "label": "Co-Signer",
          "order": 2
        },
        {
          "value": "attorney",
          "label": "Attorney",
          "order": 3
        },
        {
          "value": "bail_poster",
          "label": "Bail Poster",
          "order": 4
        },
        {
          "value": "support_contact",
          "label": "Support Contact",
          "order": 5
        }
      ],
      "defaultRole": "defendant",
      "cascadeDelete": false,
      "required": true
    }
  ],
  "suggestedRoles": [
    {
      "name": "Fund Coordinator",
      "slug": "fund-coordinator",
      "description": "Approves bail disbursements, manages fund operations, full case access",
      "permissions": [
        "cases:*",
        "contacts:*",
        "events:*",
        "evidence:*",
        "calls:*",
        "notes:*",
        "reports:*",
        "shifts:read",
        "volunteers:read",
        "hubs:read"
      ]
    },
    {
      "name": "Bail Poster",
      "slug": "bail-poster",
      "description": "Goes to court or jail to physically post bail, updates posting status",
      "permissions": [
        "cases:read-own",
        "cases:update-own",
        "contacts:view",
        "notes:create",
        "notes:read-own",
        "contacts:search"
      ]
    },
    {
      "name": "Court Monitor",
      "slug": "court-monitor",
      "description": "Tracks court dates, monitors appearances, updates case status",
      "permissions": [
        "cases:read-all",
        "cases:update",
        "contacts:view",
        "notes:create",
        "notes:read-all",
        "contacts:search",
        "cases:unlink"
      ]
    },
    {
      "name": "Finance Admin",
      "slug": "finance-admin",
      "description": "Manages fund accounting, tracks disbursements and returns",
      "permissions": [
        "cases:read-all",
        "cases:update",
        "contacts:view",
        "contacts:view-pii",
        "reports:*",
        "contacts:search",
        "hubs:read",
        "cases:unlink"
      ]
    }
  ]
}
