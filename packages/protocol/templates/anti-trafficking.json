{
  "id": "anti-trafficking",
  "version": "1.0.0",
  "name": "Anti-Trafficking Hotline",
  "description": "Human trafficking tip intake and survivor services coordination. Tracks trafficking type, potential victims, law enforcement referrals, immigration relief options, and multi-service coordination. Designed for anti-trafficking organizations and tip lines.",
  "author": "Llamenos Project",
  "license": "CC-BY-SA-4.0",
  "tags": [
    "trafficking",
    "survivor-services"
  ],
  "extends": [],
  "labels": {
    "en": {
      "trafficking_case.label": "Trafficking Case",
      "trafficking_case.labelPlural": "Trafficking Cases",
      "trafficking_case.description": "Track a trafficking tip from intake through investigation, survivor services, and case resolution"
    },
    "es": {
      "trafficking_case.label": "Caso de Trata",
      "trafficking_case.labelPlural": "Casos de Trata",
      "trafficking_case.description": "Seguimiento de un caso de trata desde la denuncia hasta los servicios para sobrevivientes"
    }
  },
  "entityTypes": [
    {
      "name": "trafficking_case",
      "label": "trafficking_case.label",
      "labelPlural": "trafficking_case.labelPlural",
      "description": "trafficking_case.description",
      "icon": "link-2",
      "color": "#e11d48",
      "category": "case",
      "numberPrefix": "TC",
      "numberingEnabled": true,
      "defaultAccessLevel": "assigned",
      "piiFields": [
        "country_of_origin",
        "language_needs",
        "law_enforcement_referral",
        "agency_referred"
      ],
      "allowSubRecords": false,
      "allowFileAttachments": true,
      "allowInteractionLinks": true,
      "showInNavigation": true,
      "showInDashboard": true,
      "statuses": [
        {
          "value": "tip_received",
          "label": "Tip Received",
          "color": "#f59e0b",
          "order": 1
        },
        {
          "value": "under_investigation",
          "label": "Under Investigation",
          "color": "#3b82f6",
          "order": 2
        },
        {
          "value": "services_coordinated",
          "label": "Services Coordinated",
          "color": "#8b5cf6",
          "order": 3
        },
        {
          "value": "survivor_safe",
          "label": "Survivor Safe",
          "color": "#22c55e",
          "order": 4
        },
        {
          "value": "case_closed",
          "label": "Case Closed",
          "color": "#6b7280",
          "order": 5,
          "isClosed": true
        }
      ],
      "defaultStatus": "tip_received",
      "closedStatuses": [
        "case_closed"
      ],
      "severities": [
        {
          "value": "critical",
          "label": "Critical (minors, imminent danger)",
          "color": "#ef4444",
          "icon": "alert-triangle",
          "order": 1
        },
        {
          "value": "high",
          "label": "High",
          "color": "#f59e0b",
          "order": 2
        },
        {
          "value": "standard",
          "label": "Standard",
          "color": "#3b82f6",
          "order": 3
        },
        {
          "value": "informational",
          "label": "Informational Tip",
          "color": "#6b7280",
          "order": 4
        }
      ],
      "defaultSeverity": "standard",
      "contactRoles": [
        {
          "value": "potential_victim",
          "label": "Potential Victim",
          "order": 1
        },
        {
          "value": "tipster",
          "label": "Tipster",
          "order": 2
        },
        {
          "value": "service_provider",
          "label": "Service Provider",
          "order": 3
        },
        {
          "value": "law_enforcement",
          "label": "Law Enforcement Contact",
          "order": 4
        },
        {
          "value": "attorney",
          "label": "Attorney",
          "order": 5
        },
        {
          "value": "interpreter",
          "label": "Interpreter",
          "order": 6
        }
      ],
      "fields": [
        {
          "name": "trafficking_type",
          "label": "Trafficking Type",
          "type": "select",
          "required": true,
          "options": [
            {
              "key": "labor",
              "label": "Labor Trafficking"
            },
            {
              "key": "sex",
              "label": "Sex Trafficking"
            },
            {
              "key": "domestic_servitude",
              "label": "Domestic Servitude"
            },
            {
              "key": "forced_criminality",
              "label": "Forced Criminality"
            },
            {
              "key": "unknown",
              "label": "Unknown / Suspected"
            }
          ],
          "section": "classification",
          "order": 1,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "potential_victim_count",
          "label": "Number of Potential Victims",
          "type": "number",
          "required": false,
          "section": "classification",
          "order": 2,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "location_type",
          "label": "Location Type",
          "type": "select",
          "required": false,
          "options": [
            {
              "key": "business",
              "label": "Business"
            },
            {
              "key": "residence",
              "label": "Residence"
            },
            {
              "key": "farm",
              "label": "Farm / Agricultural"
            },
            {
              "key": "factory",
              "label": "Factory / Manufacturing"
            },
            {
              "key": "restaurant",
              "label": "Restaurant / Food Service"
            },
            {
              "key": "construction",
              "label": "Construction Site"
            },
            {
              "key": "massage_parlor",
              "label": "Massage Parlor"
            },
            {
              "key": "hotel",
              "label": "Hotel / Motel"
            },
            {
              "key": "online",
              "label": "Online / Remote"
            },
            {
              "key": "other",
              "label": "Other"
            }
          ],
          "section": "classification",
          "order": 3,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "law_enforcement_referral",
          "label": "Law Enforcement Referral Made",
          "type": "checkbox",
          "required": false,
          "section": "referrals",
          "order": 4,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "admin"
        },
        {
          "name": "agency_referred",
          "label": "Agency Referred To",
          "type": "text",
          "required": false,
          "section": "referrals",
          "helpText": "Law enforcement agency or task force the case was referred to.",
          "order": 5,
          "indexable": false,
          "accessLevel": "admin",
          "showWhen": {
            "field": "law_enforcement_referral",
            "operator": "equals",
            "value": true
          }
        },
        {
          "name": "immigration_relief",
          "label": "Immigration Relief Available",
          "type": "select",
          "required": false,
          "options": [
            {
              "key": "t_visa",
              "label": "T-Visa (Trafficking Victims)"
            },
            {
              "key": "u_visa",
              "label": "U-Visa (Crime Victims)"
            },
            {
              "key": "sijs",
              "label": "SIJS (Special Immigrant Juvenile)"
            },
            {
              "key": "asylum",
              "label": "Asylum"
            },
            {
              "key": "none",
              "label": "None Available"
            },
            {
              "key": "unknown",
              "label": "Unknown / Under Review"
            }
          ],
          "section": "legal",
          "order": 6,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "country_of_origin",
          "label": "Country of Origin",
          "type": "text",
          "required": false,
          "section": "demographics",
          "order": 7,
          "indexable": false,
          "accessLevel": "admin"
        },
        {
          "name": "language_needs",
          "label": "Language Needs",
          "type": "text",
          "required": false,
          "section": "demographics",
          "helpText": "Primary language and interpreter needs.",
          "order": 8,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "minor_involved",
          "label": "Minor Involved",
          "type": "checkbox",
          "required": true,
          "section": "flags",
          "helpText": "Any potential victim under 18 requires immediate escalation and mandatory reporting.",
          "order": 9,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "services_needed",
          "label": "Services Needed",
          "type": "multiselect",
          "required": false,
          "options": [
            {
              "key": "housing",
              "label": "Housing / Shelter"
            },
            {
              "key": "medical",
              "label": "Medical Care"
            },
            {
              "key": "mental_health",
              "label": "Mental Health"
            },
            {
              "key": "legal",
              "label": "Legal Representation"
            },
            {
              "key": "immigration",
              "label": "Immigration Assistance"
            },
            {
              "key": "substance_abuse",
              "label": "Substance Abuse Treatment"
            },
            {
              "key": "job_training",
              "label": "Job Training / Employment"
            },
            {
              "key": "education",
              "label": "Education"
            },
            {
              "key": "childcare",
              "label": "Childcare"
            },
            {
              "key": "transportation",
              "label": "Transportation"
            }
          ],
          "section": "services",
          "helpText": "All services needed for the survivor(s).",
          "order": 10,
          "indexable": false,
          "accessLevel": "assigned"
        }
      ]
    }
  ],
  "relationshipTypes": [
    {
      "sourceEntityTypeName": "contact",
      "targetEntityTypeName": "trafficking_case",
      "cardinality": "M:N",
      "label": "Trafficking Cases",
      "reverseLabel": "Contacts",
      "sourceLabel": "has case",
      "targetLabel": "involves",
      "roles": [
        {
          "value": "potential_victim",
          "label": "Potential Victim",
          "order": 1
        },
        {
          "value": "tipster",
          "label": "Tipster",
          "order": 2
        },
        {
          "value": "service_provider",
          "label": "Service Provider",
          "order": 3
        },
        {
          "value": "law_enforcement",
          "label": "Law Enforcement Contact",
          "order": 4
        },
        {
          "value": "attorney",
          "label": "Attorney",
          "order": 5
        },
        {
          "value": "interpreter",
          "label": "Interpreter",
          "order": 6
        }
      ],
      "defaultRole": "potential_victim",
      "cascadeDelete": false,
      "required": true
    }
  ],
  "suggestedRoles": [
    {
      "name": "Intake Specialist",
      "slug": "intake-specialist",
      "description": "Receives tips, conducts initial assessments, creates case records",
      "permissions": [
        "cases:create",
        "cases:read-own",
        "cases:update-own",
        "contacts:create",
        "contacts:view",
        "calls:answer",
        "calls:read-active",
        "notes:create",
        "notes:read-own",
        "shifts:read-own",
        "calls:hangup",
        "calls:report-spam",
        "calls:identify-caller",
        "contacts:search"
      ]
    },
    {
      "name": "Case Coordinator",
      "slug": "case-coordinator",
      "description": "Coordinates survivor services, manages referrals, tracks case progress",
      "permissions": [
        "cases:read-all",
        "cases:update",
        "cases:assign",
        "contacts:view",
        "contacts:view-pii",
        "contacts:edit",
        "contacts:manage-relationships",
        "notes:create",
        "notes:read-all",
        "events:read",
        "contacts:search",
        "cases:unlink"
      ]
    },
    {
      "name": "Program Director",
      "slug": "program-director",
      "description": "Oversees all cases, manages staff, reviews high-priority cases, generates reports",
      "permissions": [
        "cases:*",
        "contacts:*",
        "events:*",
        "evidence:*",
        "calls:*",
        "notes:*",
        "conversations:*",
        "reports:*",
        "shifts:read",
        "volunteers:read",
        "hubs:read"
      ]
    }
  ]
}
