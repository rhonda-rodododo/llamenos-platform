{
  "id": "mutual-aid",
  "version": "1.0.0",
  "name": "Disaster Response / Mutual Aid",
  "description": "Mutual aid network coordination for disaster response and resource distribution. Tracks aid requests, urgency, household needs, resource delivery, and volunteer assignments. Optimized for high-volume intake during emergencies with simple statuses for fast processing.",
  "author": "Llamenos Project",
  "license": "CC-BY-SA-4.0",
  "tags": [
    "mutual-aid",
    "disaster",
    "resources"
  ],
  "extends": [],
  "labels": {
    "en": {
      "aid_request.label": "Aid Request",
      "aid_request.labelPlural": "Aid Requests",
      "aid_request.description": "Track a household's aid request from intake through resource delivery and follow-up"
    },
    "es": {
      "aid_request.label": "Solicitud de Ayuda",
      "aid_request.labelPlural": "Solicitudes de Ayuda",
      "aid_request.description": "Seguimiento de una solicitud de ayuda desde la recepcion hasta la entrega de recursos"
    }
  },
  "entityTypes": [
    {
      "name": "aid_request",
      "label": "aid_request.label",
      "labelPlural": "aid_request.labelPlural",
      "description": "aid_request.description",
      "icon": "heart",
      "color": "#e11d48",
      "category": "case",
      "numberPrefix": "MA",
      "numberingEnabled": true,
      "defaultAccessLevel": "hub",
      "piiFields": [],
      "allowSubRecords": false,
      "allowFileAttachments": false,
      "allowInteractionLinks": true,
      "showInNavigation": true,
      "showInDashboard": true,
      "statuses": [
        {
          "value": "requested",
          "label": "Requested",
          "color": "#f59e0b",
          "order": 1
        },
        {
          "value": "volunteer_assigned",
          "label": "Volunteer Assigned",
          "color": "#3b82f6",
          "order": 2
        },
        {
          "value": "in_transit",
          "label": "In Transit",
          "color": "#8b5cf6",
          "order": 3
        },
        {
          "value": "delivered",
          "label": "Delivered",
          "color": "#22c55e",
          "order": 4
        },
        {
          "value": "follow_up",
          "label": "Follow-Up Needed",
          "color": "#0ea5e9",
          "order": 5
        },
        {
          "value": "resolved",
          "label": "Resolved",
          "color": "#6b7280",
          "order": 6,
          "isClosed": true
        }
      ],
      "defaultStatus": "requested",
      "closedStatuses": [
        "resolved"
      ],
      "severities": [
        {
          "value": "life_threatening",
          "label": "Life-Threatening (medical, trapped)",
          "color": "#ef4444",
          "icon": "alert-triangle",
          "order": 1
        },
        {
          "value": "urgent",
          "label": "Urgent (within 24h)",
          "color": "#f59e0b",
          "order": 2
        },
        {
          "value": "standard",
          "label": "Standard (within 48h)",
          "color": "#3b82f6",
          "order": 3
        },
        {
          "value": "ongoing",
          "label": "Ongoing Need",
          "color": "#6b7280",
          "order": 4
        }
      ],
      "defaultSeverity": "standard",
      "contactRoles": [
        {
          "value": "requester",
          "label": "Requester",
          "order": 1
        },
        {
          "value": "household_member",
          "label": "Household Member",
          "order": 2
        },
        {
          "value": "volunteer",
          "label": "Delivery Volunteer",
          "order": 3
        },
        {
          "value": "donor",
          "label": "Resource Donor",
          "order": 4
        }
      ],
      "fields": [
        {
          "name": "need_category",
          "label": "Need Category",
          "type": "select",
          "required": true,
          "options": [
            {
              "key": "water",
              "label": "Water"
            },
            {
              "key": "food",
              "label": "Food"
            },
            {
              "key": "medical",
              "label": "Medical Supplies"
            },
            {
              "key": "shelter",
              "label": "Shelter / Housing"
            },
            {
              "key": "transport",
              "label": "Transportation / Evacuation"
            },
            {
              "key": "power",
              "label": "Power / Generator / Fuel"
            },
            {
              "key": "clothing",
              "label": "Clothing / Blankets"
            },
            {
              "key": "hygiene",
              "label": "Hygiene / Sanitation"
            },
            {
              "key": "childcare",
              "label": "Childcare"
            },
            {
              "key": "other",
              "label": "Other"
            }
          ],
          "section": "request",
          "order": 1,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "urgency",
          "label": "Urgency",
          "type": "select",
          "required": true,
          "options": [
            {
              "key": "immediate",
              "label": "Immediate"
            },
            {
              "key": "within_24h",
              "label": "Within 24 Hours"
            },
            {
              "key": "within_48h",
              "label": "Within 48 Hours"
            },
            {
              "key": "ongoing",
              "label": "Ongoing"
            }
          ],
          "section": "request",
          "order": 2,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "people_count",
          "label": "Number of People in Household",
          "type": "number",
          "required": true,
          "section": "household",
          "order": 3,
          "indexable": false,
          "accessLevel": "all"
        },
        {
          "name": "elderly_present",
          "label": "Elderly Present",
          "type": "checkbox",
          "required": false,
          "section": "household",
          "order": 4,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "children_present",
          "label": "Children Present",
          "type": "checkbox",
          "required": false,
          "section": "household",
          "order": 5,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "disabled_mobility",
          "label": "Disability / Mobility Issues",
          "type": "checkbox",
          "required": false,
          "section": "household",
          "helpText": "Anyone in the household with mobility issues or disabilities requiring accommodation.",
          "order": 6,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "medical_equipment",
          "label": "Medical Equipment Needed",
          "type": "checkbox",
          "required": false,
          "section": "household",
          "helpText": "Requires power for medical equipment (oxygen concentrator, CPAP, dialysis, etc.).",
          "order": 7,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "all"
        },
        {
          "name": "pets",
          "label": "Pets",
          "type": "checkbox",
          "required": false,
          "section": "household",
          "helpText": "Household has pets that need accommodation.",
          "order": 8,
          "indexable": false,
          "accessLevel": "all"
        },
        {
          "name": "access_issues",
          "label": "Access Issues",
          "type": "textarea",
          "required": false,
          "section": "logistics",
          "helpText": "Flooded roads, no power, blocked access, high floors without elevator, etc.",
          "order": 9,
          "indexable": false,
          "accessLevel": "all"
        },
        {
          "name": "resources_delivered",
          "label": "Resources Delivered",
          "type": "textarea",
          "required": false,
          "section": "fulfillment",
          "helpText": "What was actually delivered. Update after each delivery.",
          "order": 10,
          "indexable": false,
          "accessLevel": "assigned"
        },
        {
          "name": "delivery_date",
          "label": "Delivery Date",
          "type": "date",
          "required": false,
          "section": "fulfillment",
          "order": 11,
          "indexable": true,
          "indexType": "exact",
          "accessLevel": "assigned"
        },
        {
          "name": "volunteer_assigned",
          "label": "Volunteer Assigned",
          "type": "text",
          "required": false,
          "section": "fulfillment",
          "helpText": "Name or ID of the volunteer assigned to this delivery.",
          "order": 12,
          "indexable": false,
          "accessLevel": "assigned"
        }
      ]
    }
  ],
  "relationshipTypes": [
    {
      "sourceEntityTypeName": "contact",
      "targetEntityTypeName": "aid_request",
      "cardinality": "M:N",
      "label": "Aid Requests",
      "reverseLabel": "Contacts",
      "sourceLabel": "has request",
      "targetLabel": "involves",
      "roles": [
        {
          "value": "requester",
          "label": "Requester",
          "order": 1
        },
        {
          "value": "household_member",
          "label": "Household Member",
          "order": 2
        },
        {
          "value": "volunteer",
          "label": "Delivery Volunteer",
          "order": 3
        },
        {
          "value": "donor",
          "label": "Resource Donor",
          "order": 4
        }
      ],
      "defaultRole": "requester",
      "cascadeDelete": false,
      "required": true
    }
  ],
  "suggestedRoles": [
    {
      "name": "Dispatch Coordinator",
      "slug": "dispatch-coordinator",
      "description": "Manages all incoming requests, assigns volunteers, prioritizes deliveries",
      "permissions": [
        "cases:*",
        "contacts:*",
        "events:*",
        "evidence:*",
        "calls:*",
        "notes:*",
        "conversations:*",
        "reports:*",
        "shifts:read",
        "volunteers:read",
        "hubs:read"
      ]
    },
    {
      "name": "Intake Volunteer",
      "slug": "intake-volunteer",
      "description": "Takes incoming aid requests by phone or in person, creates request records",
      "permissions": [
        "cases:create",
        "cases:read-own",
        "cases:update-own",
        "contacts:create",
        "contacts:view",
        "calls:answer",
        "calls:read-active",
        "notes:create",
        "notes:read-own",
        "shifts:read-own",
        "calls:hangup",
        "calls:report-spam",
        "calls:identify-caller",
        "contacts:search"
      ]
    },
    {
      "name": "Delivery Volunteer",
      "slug": "delivery-volunteer",
      "description": "Picks up and delivers resources to requesting households",
      "permissions": [
        "cases:read-own",
        "cases:update-own",
        "contacts:view",
        "notes:create",
        "notes:read-own",
        "contacts:search"
      ]
    },
    {
      "name": "Supply Manager",
      "slug": "supply-manager",
      "description": "Tracks available supplies, manages donation intake, coordinates resource allocation",
      "permissions": [
        "cases:read-all",
        "cases:update",
        "contacts:view",
        "notes:create",
        "notes:read-all",
        "reports:*",
        "contacts:search",
        "hubs:read",
        "cases:unlink"
      ]
    }
  ]
}
