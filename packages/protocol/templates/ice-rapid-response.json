      "allowSubRecords": false,
      "allowFileAttachments": true,
      "allowInteractionLinks": true,
      "showInNavigation": true,
      "showInDashboard": true,
      "statuses": [
        {
          "value": "reported",
          "label": "Reported",
          "color": "#f59e0b",
          "order": 1
        },
        {
          "value": "response_active",
          "label": "Response Active",
          "color": "#ef4444",
          "order": 2
        },
        {
          "value": "stabilized",
          "label": "Stabilized",
          "color": "#3b82f6",
          "order": 3
        },
        {
          "value": "legal_referral",
          "label": "Legal Referral",
          "color": "#8b5cf6",
          "order": 4
        },
        {
          "value": "ongoing_support",
          "label": "Ongoing Support",
          "color": "#22c55e",
          "order": 5
        },
        {
          "value": "resolved",
          "label": "Resolved",
          "color": "#6b7280",
          "order": 6,
          "isClosed": true
        }
