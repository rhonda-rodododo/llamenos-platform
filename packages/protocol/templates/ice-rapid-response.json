{
  "id": "ice-rapid-response",
  "version": "1.0.0",
  "name": "ICE Rapid Response",
  "description": "Immigration enforcement rapid response coordination. Tracks ICE operations, affected individuals, legal referrals, accompaniment deployment, and know-your-rights outreach. Designed for immigrant rights rapid response networks.",
  "author": "Llamenos Project",
  "license": "CC-BY-SA-4.0",
  "tags": [
    "immigration",
    "ice",
    "rapid-response"
  ],
  "extends": [],
  "labels": {
    "en": {
      "immigration_case.label": "Immigration Case",
      "immigration_case.labelPlural": "Immigration Cases",
      "immigration_case.description": "Track an affected individual or family through an ICE enforcement action, legal referral, and ongoing support",
      "ice_operation.label": "ICE Operation",
      "ice_operation.labelPlural": "ICE Operations",
      "ice_operation.description": "An ICE enforcement action at a specific location. Links to individual immigration cases."
    },
    "es": {
      "immigration_case.label": "Caso de Inmigracion",
      "immigration_case.labelPlural": "Casos de Inmigracion",
      "immigration_case.description": "Seguimiento de una persona o familia afectada por una accion de ICE",
      "ice_operation.label": "Operacion de ICE",
      "ice_operation.labelPlural": "Operaciones de ICE",
      "ice_operation.description": "Una accion de aplicacion de la ley de inmigracion en un lugar especifico"
    }
  },
  "entityTypes": [
