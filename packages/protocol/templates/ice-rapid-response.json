    {
      "name": "Dispatch Coordinator",
      "slug": "dispatch-coordinator",
      "description": "Receives reports, activates rapid response teams, manages all cases and operations",
      "permissions": [
        "cases:*",
        "contacts:*",
        "events:*",
        "evidence:*",
        "calls:*",
        "notes:*",
        "conversations:*",
        "reports:*",
