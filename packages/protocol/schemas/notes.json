{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llamenos.org/schemas/notes.json",
  "title": "Note Types",
  "description": "Encrypted note payloads and custom field definitions",
  "$defs": {
    "NotePayload": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "description": "Note text content" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          },
          "description": "Custom field values"
        }
      },
      "additionalProperties": false
    },
    "CustomFieldContext": {
      "type": "string",
      "enum": ["call-notes", "conversation-notes", "reports", "all"]
    },
    "CustomFieldDefinition": {
      "type": "object",
      "required": ["id", "name", "label", "type", "required", "visibleToVolunteers", "editableByVolunteers", "context", "order", "createdAt"],
      "properties": {
        "id": { "type": "string", "description": "Unique UUID" },
        "name": { "type": "string", "description": "Internal key (machine-readable)" },
        "label": { "type": "string", "description": "Display label" },
        "type": { "type": "string", "enum": ["text", "number", "select", "checkbox", "textarea", "file"] },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For select type only"
        },
        "validation": {
          "type": "object",
          "properties": {
            "minLength": { "type": "number" },
            "maxLength": { "type": "number" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "additionalProperties": false
        },
        "visibleToVolunteers": { "type": "boolean" },
        "editableByVolunteers": { "type": "boolean" },
        "context": { "$ref": "#/$defs/CustomFieldContext" },
        "maxFileSize": { "type": "number", "description": "Max file size in bytes" },
        "allowedMimeTypes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g., ['image/*', 'application/pdf']"
        },
        "maxFiles": { "type": "number", "description": "For multi-file fields (default: 1)" },
        "order": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
