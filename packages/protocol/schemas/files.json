{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llamenos.org/schemas/files.json",
  "title": "File Types",
  "description": "Encrypted file records and upload types",
  "$defs": {
    "EncryptedFileMetadata": {
      "type": "object",
      "required": ["originalName", "mimeType", "size", "checksum"],
      "properties": {
        "originalName": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "dimensions": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        "duration": { "type": "number" },
        "checksum": { "type": "string", "description": "SHA-256 of plaintext for integrity verification" }
      },
      "additionalProperties": false
    },
    "EncryptedMetadataEntry": {
      "type": "object",
      "required": ["pubkey", "encryptedContent", "ephemeralPubkey"],
      "properties": {
        "pubkey": { "type": "string" },
        "encryptedContent": { "type": "string" },
        "ephemeralPubkey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "FileRecord": {
      "type": "object",
      "required": ["id", "conversationId", "uploadedBy", "recipientEnvelopes", "encryptedMetadata", "totalSize", "totalChunks", "status", "completedChunks", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "messageId": { "type": "string" },
        "uploadedBy": { "type": "string", "description": "Pubkey of uploader" },
        "recipientEnvelopes": {
          "type": "array",
          "items": { "$ref": "envelope.json#/$defs/FileKeyEnvelope" }
        },
        "encryptedMetadata": {
          "type": "array",
          "items": { "$ref": "#/$defs/EncryptedMetadataEntry" }
        },
        "totalSize": { "type": "number", "description": "Encrypted size in bytes" },
        "totalChunks": { "type": "number" },
        "status": { "type": "string", "enum": ["uploading", "complete", "failed"] },
        "completedChunks": { "type": "number" },
        "createdAt": { "type": "string" },
        "completedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UploadInit": {
      "type": "object",
      "required": ["totalSize", "totalChunks", "conversationId", "recipientEnvelopes", "encryptedMetadata"],
      "properties": {
        "totalSize": { "type": "number" },
        "totalChunks": { "type": "number" },
        "conversationId": { "type": "string" },
        "recipientEnvelopes": {
          "type": "array",
          "items": { "$ref": "envelope.json#/$defs/FileKeyEnvelope" }
        },
        "encryptedMetadata": {
          "type": "array",
          "items": { "$ref": "#/$defs/EncryptedMetadataEntry" }
        }
      },
      "additionalProperties": false
    }
  }
}
