        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 4 },
