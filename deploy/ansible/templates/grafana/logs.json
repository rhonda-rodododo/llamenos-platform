      "title": "Log Volume",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(service) (rate({project=\"llamenos\"} [5m]))",
          "legendFormat": "{{service}}",
