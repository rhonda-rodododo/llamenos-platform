# Asterisk PBX — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}

name: llamenos-asterisk

services:
  asterisk:
    image: {{ llamenos_asterisk_image }}
    restart: unless-stopped
    volumes:
      - asterisk-config:/etc/asterisk
    networks:
      - internal
    healthcheck:
      test: ["CMD", "asterisk", "-rx", "core show version"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    security_opt:
      - no-new-privileges:true

  sip-bridge:
    image: {{ llamenos_app_image }}-sip-bridge
    restart: unless-stopped
    env_file:
      - .env.asterisk
    networks:
      - internal
    depends_on:
      asterisk:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true

volumes:
  asterisk-config:

networks:
  internal:
    driver: bridge
    internal: true
