# Loki Docker Compose — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.

name: llamenos

services:
  loki:
    image: {{ loki_image }}
    restart: unless-stopped
    command:
      - "-config.file=/etc/loki/loki-config.yml"
    volumes:
      - ./loki-config.yml:/etc/loki/loki-config.yml:ro
      - ./data:/loki
    networks:
      - monitoring
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3100/ready"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 256M

networks:
  monitoring:
    name: llamenos_monitoring
    external: true
