# RustFS Object Storage — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}

name: llamenos-rustfs

services:
  rustfs:
    image: {{ llamenos_rustfs_image }}
    command: server /data --console-address ":9001"
    restart: unless-stopped
    volumes:
      - rustfs-data:/data
    env_file:
      - .env.rustfs
{% if llamenos_internal_tls_enabled %}
    ports:
      - "{{ llamenos_rustfs_port | default('9000') }}:9000"
      - "9001:9001"
{% elif groups.get('llamenos_app', []) | length > 0 and groups['llamenos_app'] | intersect(groups.get('llamenos_storage', [])) | length == 0 %}
    # App is on a different host — expose port for cross-host access
    ports:
      - "{{ llamenos_rustfs_port | default('9000') }}:9000"
      - "9001:9001"
{% else %}
    networks:
      - internal
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 256M

volumes:
  rustfs-data:

{% if not llamenos_internal_tls_enabled and not (groups.get('llamenos_app', []) | length > 0 and groups['llamenos_app'] | intersect(groups.get('llamenos_storage', [])) | length == 0) %}
networks:
  internal:
    driver: bridge
    internal: true
{% endif %}
