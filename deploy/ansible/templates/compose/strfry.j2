# strfry Nostr Relay — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}

name: llamenos-strfry

services:
  strfry:
    image: {{ llamenos_strfry_image }}
    restart: unless-stopped
    volumes:
      - nostr-data:/app/strfry-db
{% if llamenos_internal_tls_enabled %}
    ports:
      - "{{ llamenos_strfry_port | default('7777') }}:7777"
{% elif groups.get('llamenos_app', []) | length > 0 and groups['llamenos_app'] | intersect(groups.get('llamenos_relay', [])) | length == 0 %}
    # App is on a different host — expose port for cross-host access
    ports:
      - "{{ llamenos_strfry_port | default('7777') }}:7777"
{% else %}
    networks:
      - internal
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:7777"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true

volumes:
  nostr-data:

{% if not llamenos_internal_tls_enabled and not (groups.get('llamenos_app', []) | length > 0 and groups['llamenos_app'] | intersect(groups.get('llamenos_relay', [])) | length == 0) %}
networks:
  internal:
    driver: bridge
    internal: true
{% endif %}
