# DEPRECATED: This monolithic compose template is kept for backward compatibility.
# New deployments should use per-service templates in templates/compose/*.j2
# with the multi-host inventory and per-service roles.
#
# To migrate an existing deployment:
#   ansible-playbook playbooks/migrate-to-multi-host.yml --ask-vault-pass
#
# Llamenos Docker Compose — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
#
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}
# Domain: {{ domain }}

name: llamenos

services:
  # ── Core Services ──────────────────────────────────────────

  app:
    image: {{ llamenos_image }}
    restart: unless-stopped
    read_only: true
    tmpfs:
      - /tmp:size=64M
    environment:
      - PLATFORM=bun
      - PORT=3000
      - DATABASE_URL=postgresql://llamenos:${PG_PASSWORD}@postgres:5432/llamenos
      - PG_POOL_SIZE=${PG_POOL_SIZE}
      - ADMIN_PUBKEY=${ADMIN_PUBKEY}
      - HOTLINE_NAME=${HOTLINE_NAME}
      - ENVIRONMENT=${ENVIRONMENT}
      - HMAC_SECRET=${HMAC_SECRET}
      - S3_ENDPOINT=http://rustfs:9000
      - S3_ACCESS_KEY=${S3_ACCESS_KEY}
      - S3_SECRET_KEY=${S3_SECRET_KEY}
      - S3_BUCKET=${S3_BUCKET}
      - WHISPER_URL=${WHISPER_URL}
      - TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
      - TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
      - TWILIO_PHONE_NUMBER=${TWILIO_PHONE_NUMBER}
      - SERVER_NOSTR_SECRET=${SERVER_NOSTR_SECRET}
      - NOSTR_RELAY_URL=${NOSTR_RELAY_URL}
{% if 'monitoring' in compose_profiles %}
      - GLITCHTIP_DSN=${GLITCHTIP_DSN}
{% endif %}
    networks:
      - web
      - internal
    depends_on:
      postgres:
        condition: service_healthy
      rustfs:
        condition: service_healthy
      strfry:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 20s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

  postgres:
    image: {{ postgres_image }}
    restart: unless-stopped
    volumes:
      - postgres-data:/var/lib/postgresql/data
    environment:
      - POSTGRES_DB=llamenos
      - POSTGRES_USER=llamenos
      - POSTGRES_PASSWORD=${PG_PASSWORD}
    networks:
      - internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U llamenos -d llamenos"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    networks:
      - web
    depends_on:
      app:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 128M

  rustfs:
    image: {{ rustfs_image }}
    command: server /data --console-address ":9001"
    restart: unless-stopped
    volumes:
      - rustfs-data:/data
    environment:
      - RUSTFS_ROOT_USER=${S3_ACCESS_KEY}
      - RUSTFS_ROOT_PASSWORD=${S3_SECRET_KEY}
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 256M

{% if 'transcription' in compose_profiles %}
  # ── Optional: Whisper Transcription ──────────────────────────

  whisper:
    image: {{ whisper_image }}
    restart: unless-stopped
    environment:
      - WHISPER__MODEL=${WHISPER_MODEL}
      - WHISPER__DEVICE=${WHISPER_DEVICE}
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
{% endif %}

{% if 'asterisk' in compose_profiles %}
  # ── Optional: Asterisk PBX ──────────────────────────────────

  asterisk:
    image: {{ asterisk_image }}
    restart: unless-stopped
    volumes:
      - asterisk-config:/etc/asterisk
    networks:
      - internal
    healthcheck:
      test: ["CMD", "asterisk", "-rx", "core show version"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    security_opt:
      - no-new-privileges:true

  sip-bridge:
    image: {{ llamenos_image }}-sip-bridge
    restart: unless-stopped
    environment:
      - PBX_TYPE=${PBX_TYPE:-asterisk}
      - ARI_URL=ws://asterisk:8088/ari/events
      - ARI_USERNAME=${ARI_USERNAME}
      - ARI_PASSWORD=${ARI_PASSWORD}
      - WORKER_WEBHOOK_URL=http://app:3000
      - BRIDGE_SECRET=${BRIDGE_SECRET}
    networks:
      - internal
    depends_on:
      asterisk:
        condition: service_healthy
      app:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
{% endif %}

  # ── Core: Nostr Relay (strfry) ──────────────────────────────

  strfry:
    image: {{ strfry_image }}
    restart: unless-stopped
    volumes:
      - nostr-data:/app/strfry-db
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:7777"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true

{% if 'monitoring' in compose_profiles %}
  # ── Optional: GlitchTip Error Tracking ─────────────────────

  glitchtip:
    image: {{ glitchtip_image }}
    restart: unless-stopped
    environment:
      - DATABASE_URL=postgresql://llamenos:${PG_PASSWORD}@postgres:5432/glitchtip
      - SECRET_KEY=${GLITCHTIP_SECRET_KEY}
      - PORT=8000
      - EMAIL_URL=${GLITCHTIP_EMAIL_URL}
      - GLITCHTIP_DOMAIN=${GLITCHTIP_DOMAIN}
      - DEFAULT_FROM_EMAIL=${GLITCHTIP_FROM_EMAIL}
      - CELERY_WORKER_AUTOSCALE=1,3
      - CELERY_WORKER_MAX_TASKS_PER_CHILD=10000
    networks:
      - web
      - internal
    depends_on:
      postgres:
        condition: service_healthy
      glitchtip-redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/_health/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

  glitchtip-worker:
    image: {{ glitchtip_image }}
    restart: unless-stopped
    command: ./bin/run-celery-with-beat.sh
    environment:
      - DATABASE_URL=postgresql://llamenos:${PG_PASSWORD}@postgres:5432/glitchtip
      - SECRET_KEY=${GLITCHTIP_SECRET_KEY}
      - EMAIL_URL=${GLITCHTIP_EMAIL_URL}
      - GLITCHTIP_DOMAIN=${GLITCHTIP_DOMAIN}
      - DEFAULT_FROM_EMAIL=${GLITCHTIP_FROM_EMAIL}
      - CELERY_WORKER_AUTOSCALE=1,3
      - CELERY_WORKER_MAX_TASKS_PER_CHILD=10000
    networks:
      - internal
    depends_on:
      postgres:
        condition: service_healthy
      glitchtip-redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true

  glitchtip-redis:
    image: {{ glitchtip_redis_image }}
    restart: unless-stopped
    networks:
      - internal
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    security_opt:
      - no-new-privileges:true
{% endif %}

{% if 'signal' in compose_profiles %}
  # ── Optional: Signal Messaging ──────────────────────────────

  signal-cli:
    image: {{ signal_image }}
    restart: unless-stopped
    environment:
      - MODE=json-rpc
      - AUTO_RECEIVE_SCHEDULE=0 * * * *
    volumes:
      - signal-data:/home/.local/share/signal-cli
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/v1/about"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    security_opt:
      - no-new-privileges:true
{% endif %}

volumes:
  postgres-data:
  caddy-data:
  caddy-config:
  rustfs-data:
  nostr-data:
{% if 'asterisk' in compose_profiles %}
  asterisk-config:
{% endif %}
{% if 'signal' in compose_profiles %}
  signal-data:
{% endif %}

networks:
  web:
    driver: bridge
  internal:
    driver: bridge
    internal: true
