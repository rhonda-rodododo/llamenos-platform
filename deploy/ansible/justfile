# Llamenos Ansible Deployment Commands
#
# Prerequisites:
#   - Ansible installed (pip install ansible)
#   - just installed (https://github.com/casey/just)
#   - inventory.yml and vars.yml configured
#
# Quick start:
#   cp inventory.example.yml inventory.yml
#   cp vars.example.yml vars.yml
#   # Edit both files with your values
#   ansible-vault encrypt vars.yml
#   just setup-all

# Default recipe: show available commands
default:
    @just --list

# ── Full Setup ──────────────────────────────────────────────────

# Full server setup: harden + deploy
setup-all *ARGS:
    ansible-playbook setup.yml --ask-vault-pass {{ARGS}}

# Harden the server (SSH, firewall, kernel, fail2ban, Docker)
harden *ARGS:
    ansible-playbook playbooks/harden.yml --ask-vault-pass {{ARGS}}

# ── Deployment ──────────────────────────────────────────────────

# Deploy or update all services (multi-host orchestration)
deploy *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass {{ARGS}}

# Pull latest images and restart with health check and rollback
update *ARGS:
    ansible-playbook playbooks/update.yml --ask-vault-pass {{ARGS}}

# ── Per-Service Deployment ──────────────────────────────────────

# Deploy only the app service
deploy-app *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags app {{ARGS}}

# Deploy only PostgreSQL
deploy-postgres *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags postgres {{ARGS}}

# Deploy only Caddy reverse proxy
deploy-caddy *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags caddy {{ARGS}}

# Deploy only MinIO object storage
deploy-minio *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags minio {{ARGS}}

# Deploy only strfry Nostr relay
deploy-strfry *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags strfry {{ARGS}}

# Deploy only Whisper transcription
deploy-whisper *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags whisper {{ARGS}}

# Deploy only Asterisk PBX
deploy-asterisk *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags asterisk {{ARGS}}

# Deploy only Signal bridge
deploy-signal *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass --tags signal {{ARGS}}

# ── Migration ───────────────────────────────────────────────────

# Migrate from monolithic to per-service layout
migrate *ARGS:
    ansible-playbook playbooks/migrate-to-multi-host.yml --ask-vault-pass {{ARGS}}

# ── Backup ──────────────────────────────────────────────────────

# Run all backups (postgres, strfry, minio, config) with monitoring
backup *ARGS:
    ansible-playbook playbooks/backup.yml --ask-vault-pass {{ARGS}}

# Run backup for a specific service only (postgres, strfry, minio, config)
backup-service SERVICE *ARGS:
    ansible-playbook playbooks/backup.yml --ask-vault-pass --tags {{SERVICE}} {{ARGS}}

# Check backup health status
backup-status *ARGS:
    ansible-playbook playbooks/backup-status.yml --ask-vault-pass {{ARGS}}

# Restore from backup (interactive — shows what will happen first)
restore *ARGS:
    ansible-playbook playbooks/restore.yml --ask-vault-pass {{ARGS}}

# Restore dry-run (shows what would be restored without making changes)
restore-dry-run *ARGS:
    ansible-playbook playbooks/restore.yml --ask-vault-pass -e restore_dry_run=true {{ARGS}}

# Test backup restoration in isolated container (non-destructive)
test-restore *ARGS:
    ansible-playbook playbooks/test-restore.yml --ask-vault-pass {{ARGS}}

# ── Observability ─────────────────────────────────────────────────

# Deploy or update the observability stack (Prometheus, Grafana, Loki, etc.)
observability *ARGS:
    ansible-playbook playbooks/observability.yml --ask-vault-pass {{ARGS}}

# Deploy only Prometheus
prometheus *ARGS:
    ansible-playbook playbooks/observability.yml --ask-vault-pass --tags prometheus {{ARGS}}

# Deploy only Grafana
grafana *ARGS:
    ansible-playbook playbooks/observability.yml --ask-vault-pass --tags grafana {{ARGS}}

# Deploy only Loki + Promtail (log aggregation)
logs *ARGS:
    ansible-playbook playbooks/observability.yml --ask-vault-pass --tags loki,promtail {{ARGS}}

# Deploy only Alertmanager
alertmanager *ARGS:
    ansible-playbook playbooks/observability.yml --ask-vault-pass --tags alertmanager {{ARGS}}

# ── Verification ────────────────────────────────────────────────

# Check configuration without making changes
check *ARGS:
    ansible-playbook setup.yml --check --diff --ask-vault-pass {{ARGS}}

# Test SSH connectivity to all hosts
ping:
    ansible all -m ping

# Show gathered facts for debugging
facts:
    ansible all -m setup --ask-vault-pass

# ── Vault Management ───────────────────────────────────────────

# Encrypt the vars file with Ansible Vault
encrypt-vars:
    ansible-vault encrypt vars.yml

# Edit encrypted vars file
edit-vars:
    ansible-vault edit vars.yml

# View encrypted vars file
view-vars:
    ansible-vault view vars.yml

# ── Utilities ──────────────────────────────────────────────────

# Check watchdog status (timer and recent runs)
watchdog-status *ARGS:
    ansible all -m shell -a "systemctl status llamenos-watchdog.timer; echo '---'; journalctl -u llamenos-watchdog.service --no-pager -n 20" --ask-vault-pass {{ARGS}}

# Run maintenance cleanup manually
maintenance-run *ARGS:
    ansible all -m shell -a "{{ app_dir | default('/opt/llamenos') }}/scripts/maintenance-cleanup.sh" --become --ask-vault-pass {{ARGS}}

# Run PostgreSQL vacuum manually
vacuum-run *ARGS:
    ansible all -m shell -a "{{ app_dir | default('/opt/llamenos') }}/scripts/maintenance-vacuum.sh" --become --ask-vault-pass {{ARGS}}

# Check NTP drift status
ntp-status *ARGS:
    ansible all -m shell -a "chronyc tracking; echo '---'; tail -5 {{ app_dir | default('/opt/llamenos') }}/logs/ntp-monitor.log 2>/dev/null || echo 'No NTP monitor log yet'" --ask-vault-pass {{ARGS}}

# Check disk space and recent alerts
disk-status *ARGS:
    ansible all -m shell -a "df -h /opt/llamenos; echo '---'; tail -5 {{ app_dir | default('/opt/llamenos') }}/logs/disk-monitor.log 2>/dev/null || echo 'No disk monitor log yet'" --ask-vault-pass {{ARGS}}

# Check certificate expiry
cert-status *ARGS:
    ansible all -m shell -a "{{ app_dir | default('/opt/llamenos') }}/scripts/cert-monitor.sh 2>&1 || echo 'Cert monitor not configured'" --ask-vault-pass {{ARGS}}

# View recent watchdog logs
watchdog-logs *ARGS:
    ansible all -m shell -a "tail -50 {{ app_dir | default('/opt/llamenos') }}/logs/watchdog.log 2>/dev/null || echo 'No watchdog log yet'" --ask-vault-pass {{ARGS}}

# Deploy only auto-healing components
deploy-auto-healing *ARGS:
    ansible-playbook playbooks/deploy.yml --tags auto-healing --ask-vault-pass {{ARGS}}

# Generate secrets for a new deployment
generate-secrets:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "=== Generated Secrets ==="
    echo ""
    echo "pg_password: $(openssl rand -base64 24)"
    echo "hmac_secret: $(openssl rand -hex 32)"
    echo "minio_access_key: $(openssl rand -base64 24)"
    echo "minio_secret_key: $(openssl rand -base64 24)"
    echo "server_nostr_secret: $(openssl rand -hex 32)"
    echo "ari_password: $(openssl rand -base64 24)"
    echo "bridge_secret: $(openssl rand -base64 24)"
    echo "grafana_admin_password: $(openssl rand -base64 24)"
    echo ""
    echo "Copy these into your vars.yml before encrypting."
    echo "Run: just encrypt-vars"
