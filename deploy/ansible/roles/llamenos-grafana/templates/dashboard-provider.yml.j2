# Grafana Dashboard Provisioning — managed by Ansible
apiVersion: 1

providers:
  - name: llamenos
    orgId: 1
    folder: Llamenos
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: true
    options:
      path: /var/lib/grafana/dashboards
      foldersFromFilesStructure: false
