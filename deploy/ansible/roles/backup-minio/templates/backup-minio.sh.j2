#!/usr/bin/env bash
#
# Llamenos MinIO Backup Script — managed by Ansible
#
# Uses `mc mirror` inside the MinIO container to export all objects from
# the bucket, then tars and optionally encrypts the result.
#
# Usage:
#   ./backup-minio.sh              # Run a daily backup
#   ./backup-minio.sh --manual     # Run and tag as manual backup
#   ./backup-minio.sh --manifest   # Output manifest entry to stdout

set -euo pipefail

BACKUP_DIR="{{ backup_minio_dir }}"
COMPOSE_FILE="{{ backup_compose_file }}"
AGE_RECIPIENT="{{ backup_age_public_key }}"
RCLONE_REMOTE="{{ backup_rclone_remote }}"
MINIO_BUCKET="{{ backup_minio_bucket }}"
TIMESTAMP="$(date -u +%Y%m%d-%H%M%S)"
DAY_OF_WEEK="$(date -u +%u)"
DAY_OF_MONTH="$(date -u +%d)"
MANIFEST_MODE=false

BACKUP_TYPE="daily"
for arg in "$@"; do
  case "$arg" in
    --manual) BACKUP_TYPE="manual" ;;
    --manifest) MANIFEST_MODE=true ;;
  esac
done

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [minio] $*"
}

TMPDIR="$(mktemp -d)"
trap 'rm -rf "${TMPDIR}"' EXIT

MIRROR_DIR="${TMPDIR}/minio-mirror"
mkdir -p "${MIRROR_DIR}"

log "Starting ${BACKUP_TYPE} MinIO backup..."

# Step 1: Mirror bucket contents out of the container
# mc is available inside the minio container; we use docker exec to run it
docker compose -f "${COMPOSE_FILE}" exec -T minio \
  mc alias set {{ backup_minio_alias }} http://localhost:9000 \
    "${MINIO_ROOT_USER:-}" "${MINIO_ROOT_PASSWORD:-}" \
    --api S3v4 2>/dev/null || true

# Copy objects to a temp path inside the container, then docker cp out
CONTAINER_TMP="/tmp/backup-mirror-${TIMESTAMP}"
docker compose -f "${COMPOSE_FILE}" exec -T minio \
  sh -c "mkdir -p ${CONTAINER_TMP} && mc mirror {{ backup_minio_alias }}/${MINIO_BUCKET} ${CONTAINER_TMP}/ {% if backup_minio_remove_deleted %}--remove{% endif %} {% if backup_minio_overwrite %}--overwrite{% endif %} 2>&1" || true

# Get the container name dynamically
CONTAINER_NAME="$(docker compose -f "${COMPOSE_FILE}" ps -q minio)"

# Copy mirrored files out of container
docker cp "${CONTAINER_NAME}:${CONTAINER_TMP}/." "${MIRROR_DIR}/" 2>/dev/null || true

# Clean up inside container
docker compose -f "${COMPOSE_FILE}" exec -T minio \
  rm -rf "${CONTAINER_TMP}" 2>/dev/null || true

OBJECT_COUNT="$(find "${MIRROR_DIR}" -type f | wc -l)"
log "Mirrored ${OBJECT_COUNT} objects"

# Step 2: Tar and compress
TAR_FILE="${TMPDIR}/llamenos-minio-${TIMESTAMP}.tar.gz"
tar -czf "${TAR_FILE}" -C "${MIRROR_DIR}" .
rm -rf "${MIRROR_DIR}"

DUMP_SIZE="$(stat -c%s "${TAR_FILE}")"
log "Compressed archive: ${DUMP_SIZE} bytes"

# Step 3: Compute checksum
DUMP_SHA256="$(sha256sum "${TAR_FILE}" | cut -d' ' -f1)"

# Step 4: Encrypt with age (if configured)
if [ -n "${AGE_RECIPIENT}" ]; then
  FILENAME="llamenos-minio-${TIMESTAMP}.tar.gz.age"
  log "Encrypting backup with age..."
  age -r "${AGE_RECIPIENT}" -o "${TMPDIR}/${FILENAME}" "${TAR_FILE}"
  rm -f "${TAR_FILE}"
else
  FILENAME="llamenos-minio-${TIMESTAMP}.tar.gz"
  mv "${TAR_FILE}" "${TMPDIR}/${FILENAME}"
  log "WARNING: No age public key configured. Backup is NOT encrypted."
fi

FINAL_SIZE="$(stat -c%s "${TMPDIR}/${FILENAME}")"

# Step 5: Store in daily directory
cp "${TMPDIR}/${FILENAME}" "${BACKUP_DIR}/daily/${FILENAME}"
log "Saved to ${BACKUP_DIR}/daily/${FILENAME}"

# Step 6: Copy to weekly (Sundays) and monthly (1st)
if [ "${DAY_OF_WEEK}" = "7" ]; then
  cp "${TMPDIR}/${FILENAME}" "${BACKUP_DIR}/weekly/${FILENAME}"
  log "Weekly backup saved"
fi

if [ "${DAY_OF_MONTH}" = "01" ]; then
  cp "${TMPDIR}/${FILENAME}" "${BACKUP_DIR}/monthly/${FILENAME}"
  log "Monthly backup saved"
fi

# Step 7: Upload to remote storage via rclone
if [ -n "${RCLONE_REMOTE}" ]; then
  log "Uploading to remote storage: ${RCLONE_REMOTE}"
  rclone copy "${TMPDIR}/${FILENAME}" "${RCLONE_REMOTE}/daily/" --no-traverse
  if [ "${DAY_OF_WEEK}" = "7" ]; then
    rclone copy "${TMPDIR}/${FILENAME}" "${RCLONE_REMOTE}/weekly/" --no-traverse
  fi
  if [ "${DAY_OF_MONTH}" = "01" ]; then
    rclone copy "${TMPDIR}/${FILENAME}" "${RCLONE_REMOTE}/monthly/" --no-traverse
  fi
  log "Remote upload complete"
fi

# Step 8: Enforce retention
enforce_retention() {
  local dir="$1"
  local keep="$2"
  local pattern="$3"
  local count
  count="$(find "${dir}" -maxdepth 1 -type f -name "${pattern}" | wc -l)"
  if [ "${count}" -gt "${keep}" ]; then
    local to_delete=$(( count - keep ))
    find "${dir}" -maxdepth 1 -type f -name "${pattern}" -printf '%T@ %p\n' \
      | sort -n \
      | head -n "${to_delete}" \
      | cut -d' ' -f2- \
      | xargs rm -f
    log "Removed ${to_delete} old backups from ${dir}"
  fi
}

enforce_retention "${BACKUP_DIR}/daily" {{ backup_minio_retain_daily }} 'llamenos-minio-*'
enforce_retention "${BACKUP_DIR}/weekly" {{ backup_minio_retain_weekly }} 'llamenos-minio-*'
enforce_retention "${BACKUP_DIR}/monthly" {{ backup_minio_retain_monthly }} 'llamenos-minio-*'

# Step 9: Manifest entry
MANIFEST_ENTRY="minio|${TIMESTAMP}|${FILENAME}|${FINAL_SIZE}|${DUMP_SHA256}|${BACKUP_TYPE}|objects=${OBJECT_COUNT}"
echo "${MANIFEST_ENTRY}" >> "${BACKUP_DIR}/../manifest.log"

if [ "${MANIFEST_MODE}" = true ]; then
  echo "${MANIFEST_ENTRY}"
fi

log "MinIO backup complete: ${FILENAME} (${FINAL_SIZE} bytes, ${OBJECT_COUNT} objects)"
