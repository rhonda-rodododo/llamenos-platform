# TLS Configuration — managed by Ansible
# Kamailio TLS module settings

[server:default]
method = TLSv1.2+
verify_certificate = no
require_certificate = no
private_key = /etc/kamailio/tls/kamailio.key
certificate = /etc/kamailio/tls/kamailio.crt

[client:default]
method = TLSv1.2+
verify_certificate = yes
require_certificate = no
