# Alertmanager Configuration — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.

global:
  resolve_timeout: 5m
{% if alert_notification_method == 'email' %}
  smtp_smarthost: "{{ alert_smtp_host }}:{{ alert_smtp_port }}"
  smtp_from: "{{ alert_smtp_from }}"
{% if alert_smtp_username %}
  smtp_auth_username: "{{ alert_smtp_username }}"
  smtp_auth_password: "{{ alert_smtp_password }}"
{% endif %}
  smtp_require_tls: true
{% endif %}

route:
  group_by: ["alertname", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: default
  routes:
    - match:
        severity: critical
      receiver: critical
      repeat_interval: 1h

receivers:
  - name: default
{% if alert_notification_method == 'email' %}
    email_configs:
      - to: "{{ alert_smtp_to }}"
        send_resolved: true
{% elif alert_notification_method == 'ntfy' %}
    webhook_configs:
      - url: "{{ alert_ntfy_url }}/{{ alert_ntfy_topic }}"
        send_resolved: true
{% if alert_ntfy_token %}
        http_config:
          authorization:
            credentials: "{{ alert_ntfy_token }}"
{% endif %}
{% elif alert_notification_method == 'webhook' %}
    webhook_configs:
      - url: "{{ alert_webhook_url }}"
        send_resolved: true
{% endif %}

  - name: critical
{% if alert_notification_method == 'email' %}
    email_configs:
      - to: "{{ alert_smtp_to }}"
        send_resolved: true
        headers:
          Subject: "[CRITICAL] {{ '{{ .GroupLabels.alertname }}' }}"
{% elif alert_notification_method == 'ntfy' %}
    webhook_configs:
      - url: "{{ alert_ntfy_url }}/{{ alert_ntfy_topic }}?priority=urgent&tags=rotating_light"
        send_resolved: true
{% if alert_ntfy_token %}
        http_config:
          authorization:
            credentials: "{{ alert_ntfy_token }}"
{% endif %}
{% elif alert_notification_method == 'webhook' %}
    webhook_configs:
      - url: "{{ alert_webhook_url }}"
        send_resolved: true
{% endif %}

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: ["alertname"]
