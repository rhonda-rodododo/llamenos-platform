# Llamenos Self-Hosted Configuration
# Copy this file to .env and fill in your values.
#
# SECURITY: All required values must be set before starting.
# Compose will refuse to start if required variables are missing.

# ─── Required ────────────────────────────────────────────
# Admin public key (run: bun run bootstrap-admin to generate)
ADMIN_PUBKEY=

# ─── Domain & TLS ────────────────────────────────────────
# Your domain (Caddy will auto-provision TLS certificates)
DOMAIN=localhost
ACME_EMAIL=

# Custom ports (default: 80/443)
# HTTP_PORT=80
# HTTPS_PORT=443

# ─── Application ─────────────────────────────────────────
HOTLINE_NAME=Hotline
ENVIRONMENT=production

# REQUIRED: HMAC secret for hashing phone numbers and IPs (prevents precomputation attacks).
# Must be a 64-character hex string. Generate with: openssl rand -hex 32
HMAC_SECRET=

# ─── PostgreSQL ──────────────────────────────────────────
# REQUIRED: Set a strong password for the database.
# Example: openssl rand -base64 24
PG_PASSWORD=
# PG_POOL_SIZE=10

# ─── Telephony (Twilio) ──────────────────────────────────
# Leave empty if using self-hosted Asterisk or configuring via the admin UI
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Object Storage (S3-compatible / RustFS) ────────────
# REQUIRED: Generate unique credentials — do NOT use defaults.
# Example: openssl rand -base64 24
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=llamenos-files

# ─── Transcription ───────────────────────────────────────
# Enable with: docker compose --profile transcription up -d
WHISPER_MODEL=Systran/faster-whisper-base
WHISPER_DEVICE=cpu
# Set to "cuda" if you have a GPU
# WHISPER_DEVICE=cuda

# ─── Asterisk (Self-Hosted PBX) ──────────────────────────
# Enable with: docker compose --profile asterisk up -d
# REQUIRED if using Asterisk: Generate strong, unique credentials.
# Example: openssl rand -base64 24
ARI_PASSWORD=
BRIDGE_SECRET=

# ─── Nostr Relay (Core) ─────────────────────────────────
# REQUIRED: Server secret for signing relay events (used for all real-time updates).
# Generate with: openssl rand -hex 32
SERVER_NOSTR_SECRET=
# Relay URL (defaults to ws://strfry:7777 when using the bundled strfry)
# NOSTR_RELAY_URL=ws://strfry:7777

# ─── Signal Notifier (Core) ─────────────────────────────
# REQUIRED: Shared secret between the app and the signal-notifier sidecar.
# Generate with: openssl rand -hex 32
SIGNAL_NOTIFIER_BEARER_TOKEN=
# URL for the signal-cli REST API (defaults to bundled signal-cli in signal profile)
# SIGNAL_CLI_URL=http://signal-cli:8080

# ─── LLM Inference ──────────────────────────────────────
# Enable Ollama (CPU/GPU): docker compose --profile inference up -d
# Enable vLLM  (GPU only): docker compose --profile inference-gpu up -d

# Ollama: no additional config required (models downloaded on demand)
# Pull a model: docker compose exec ollama ollama pull llama3.2

# vLLM: set the HuggingFace model ID to serve
# VLLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
# HuggingFace token (required for gated models)
# HUGGING_FACE_HUB_TOKEN=

# ─── Optional Profiles ───────────────────────────────────
# Comma-separated list of profiles to enable by default.
# Options: transcription, asterisk, signal, monitoring, inference, inference-gpu
# COMPOSE_PROFILES=transcription
