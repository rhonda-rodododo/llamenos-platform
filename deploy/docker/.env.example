# Llamenos Self-Hosted Configuration
# Copy this file to .env and fill in your values.
#
# SECURITY: All required values must be set before starting.
# Compose will refuse to start if required variables are missing.

# ─── Required ────────────────────────────────────────────
# Admin public key (run: bun run bootstrap-admin to generate)
ADMIN_PUBKEY=

# ─── Domain & TLS ────────────────────────────────────────
# Your domain (Caddy will auto-provision TLS certificates)
DOMAIN=localhost
ACME_EMAIL=

# Custom ports (default: 80/443)
# HTTP_PORT=80
# HTTPS_PORT=443

# ─── Application ─────────────────────────────────────────
HOTLINE_NAME=Hotline
ENVIRONMENT=production

# ─── PostgreSQL ──────────────────────────────────────────
# REQUIRED: Set a strong password for the database.
# Example: openssl rand -base64 24
PG_PASSWORD=
# PG_POOL_SIZE=10

# ─── Telephony (Twilio) ──────────────────────────────────
# Leave empty if using self-hosted Asterisk or configuring via the admin UI
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── MinIO (Blob Storage) ────────────────────────────────
# REQUIRED: Generate unique credentials — do NOT use defaults.
# Example: openssl rand -base64 24
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=llamenos-files

# ─── Transcription ───────────────────────────────────────
# Enable with: docker compose --profile transcription up -d
WHISPER_MODEL=Systran/faster-whisper-base
WHISPER_DEVICE=cpu
# Set to "cuda" if you have a GPU
# WHISPER_DEVICE=cuda

# ─── Asterisk (Self-Hosted PBX) ──────────────────────────
# Enable with: docker compose --profile asterisk up -d
# REQUIRED if using Asterisk: Generate a strong random secret.
# Example: openssl rand -hex 32
BRIDGE_SECRET=

# ─── Optional Profiles ───────────────────────────────────
# Comma-separated list of profiles to enable by default.
# Options: transcription, asterisk, signal
# COMPOSE_PROFILES=transcription
